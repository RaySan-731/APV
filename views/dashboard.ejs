<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard - Arrow-Park Ventures</title>
    <link rel="stylesheet" href="/css/styles.css">
    <link rel="icon" href="/favicon.ico">
</head>
<body>
    <div class="dashboard-layout">
        <!-- Sidebar -->
        <aside class="sidebar" id="sidebar">
            <div class="sidebar-header">
                <div class="sidebar-brand">
                    <svg class="sidebar-logo" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M17 14V2"></path>
                        <path d="M9 18.12L10 14H4l1.88-4.12L9 18.12z"></path>
                        <path d="M13 22l3-8"></path>
                        <path d="M7 22l3-8"></path>
                    </svg>
                    <span>Arrow-Park Ventures</span>
                </div>
                <button class="sidebar-toggle" id="sidebarToggle">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M3 12h18"></path>
                        <path d="M3 6h18"></path>
                        <path d="M3 18h18"></path>
                    </svg>
                </button>
            </div>

            <nav class="sidebar-nav">
                <div class="nav-section">
                    <h3 class="nav-section-title">Main Menu</h3>
                    <ul class="nav-list">
                        <li class="nav-item">
                            <a href="/dashboard" class="nav-link <%= page === 'dashboard' ? 'active' : '' %>">
                                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
                                    <polyline points="9,22 9,12 15,12 15,22"></polyline>
                                </svg>
                                Dashboard
                            </a>
                        </li>
                        <li class="nav-item">
                            <a href="/dashboard/analytics" class="nav-link <%= page === 'analytics' ? 'active' : '' %>">
                                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M3 3v18h18"></path>
                                    <path d="M18.7 8l-5.1 5.2-2.8-2.7L7 14.3"></path>
                                </svg>
                                Analytics
                            </a>
                        </li>
                        <li class="nav-item">
                            <a href="/dashboard/staff" class="nav-link <%= page === 'staff' ? 'active' : '' %>">
                                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                                    <circle cx="9" cy="7" r="4"></circle>
                                    <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
                                    <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
                                </svg>
                                Staff Management
                            </a>
                        </li>
                        <li class="nav-item">
                            <a href="/dashboard/schools" class="nav-link <%= page === 'schools' ? 'active' : '' %>">
                                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M12 2l3 3 3-3v8a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2V2l3 3 3-3z"></path>
                                    <path d="M2 12h20"></path>
                                    <path d="M6 12v8"></path>
                                    <path d="M18 12v8"></path>
                                </svg>
                                Schools
                            </a>
                        </li>
                        <li class="nav-item">
                            <a href="/dashboard/events" class="nav-link <%= page === 'events' ? 'active' : '' %>">
                                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                                    <line x1="16" y1="2" x2="16" y2="6"></line>
                                    <line x1="8" y1="2" x2="8" y2="6"></line>
                                    <line x1="3" y1="10" x2="21" y2="10"></line>
                                </svg>
                                Events
                            </a>
                        </li>
                        <li class="nav-item">
                            <a href="/dashboard/programs" class="nav-link <%= page === 'programs' ? 'active' : '' %>">
                                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                                    <polyline points="14,2 14,8 20,8"></polyline>
                                    <line x1="16" y1="13" x2="8" y2="13"></line>
                                    <line x1="16" y1="17" x2="8" y2="17"></line>
                                    <polyline points="10,9 9,9 8,9"></polyline>
                                </svg>
                                Programs
                            </a>
                        </li>
                        <li class="nav-item">
                            <a href="/dashboard/trainers" class="nav-link <%= page === 'trainers' ? 'active' : '' %>">
                                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                                    <circle cx="9" cy="7" r="4"></circle>
                                    <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
                                    <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
                                </svg>
                                Trainers
                            </a>
                        </li>
                        <li class="nav-item">
                            <a href="/dashboard/audit-logs" class="nav-link <%= page === 'audit-logs' ? 'active' : '' %>">
                                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                                    <polyline points="14,2 14,8 20,8"></polyline>
                                    <line x1="16" y1="13" x2="8" y2="13"></line>
                                    <line x1="16" y1="17" x2="8" y2="17"></line>
                                    <polyline points="10,9 9,9 8,9"></polyline>
                                </svg>
                                Audit Logs
                            </a>
                        </li>
                        <li class="nav-item">
                            <a href="/dashboard/permissions" class="nav-link <%= page === 'permissions' ? 'active' : '' %>">
                                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M12 2l3 3 3-3v8a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2V2l3 3 3-3z"></path>
                                    <path d="M2 12h20"></path>
                                    <path d="M6 12v8"></path>
                                    <path d="M18 12v8"></path>
                                </svg>
                                Permissions
                            </a>
                        </li>
                        <li class="nav-item">
                            <a href="/dashboard/settings" class="nav-link <%= page === 'settings' ? 'active' : '' %>">
                                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <circle cx="12" cy="12" r="3"></circle>
                                    <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1 1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"></path>
                                </svg>
                                Settings
                            </a>
                        </li>
                    </ul>
                </div>

                <div class="nav-section">
                    <h3 class="nav-section-title">Support</h3>
                    <ul class="nav-list">
                        <li class="nav-item">
                            <a href="/help" class="nav-link">
                                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <circle cx="12" cy="12" r="10"></circle>
                                    <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"></path>
                                    <path d="M12 17h.01"></path>
                                </svg>
                                Help & FAQ
                            </a>
                        </li>
                    </ul>
                </div>
            </nav>

            <div class="sidebar-footer">
                <a href="/logout" class="logout-btn">
                    <svg class="logout-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
                        <polyline points="16,17 21,12 16,7"></polyline>
                        <line x1="21" y1="12" x2="9" y2="12"></line>
                    </svg>
                    Logout
                </a>
            </div>
        </aside>

        <!-- Main Content -->
        <main class="main-content">
            <header class="dashboard-header">
                <button class="mobile-sidebar-toggle" id="mobileSidebarToggle">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M3 12h18"></path>
                        <path d="M3 6h18"></path>
                        <path d="M3 18h18"></path>
                    </svg>
                </button>
                <h1 class="page-title">
                    <% if (page === 'dashboard') { %>Dashboard<% } %>
                    <% if (page === 'analytics') { %>Analytics<% } %>
                    <% if (page === 'staff') { %>Staff Management<% } %>
                    <% if (page === 'schools') { %>Schools<% } %>
                    <% if (page === 'events') { %>Events<% } %>
                    <% if (page === 'programs') { %>Programs<% } %>
                    <% if (page === 'settings') { %>Settings<% } %>
                    <% if (page === 'trainers') { %>Trainers<% } %>
                    <% if (page === 'audit-logs') { %>Audit Logs<% } %>
                    <% if (page === 'permissions') { %>Permissions<% } %>
                    <% if (page === 'schedule') { %>Training Schedule<% } %>
                    <% if (page === 'health') { %>Health Records<% } %>
                </h1>
                <div class="user-info">
                    <span>Welcome, <%= user.name %></span>
                </div>
            </header>

            <div class="dashboard-content">
                <% if (page === 'dashboard') { %>
                    <!-- Dashboard Stats -->
                    <div class="stats-grid">
                        <div class="stat-card">
                            <div class="stat-icon">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M12 2l3 3 3-3v8a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2V2l3 3 3-3z"></path>
                                    <path d="M2 12h20"></path>
                                    <path d="M6 12v8"></path>
                                    <path d="M18 12v8"></path>
                                </svg>
                            </div>
                            <div class="stat-number" id="totalSchools">25</div>
                            <div class="stat-label">Total Schools</div>
                            <div class="stat-change">+3 this month</div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-icon">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                                    <circle cx="9" cy="7" r="4"></circle>
                                    <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
                                    <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
                                </svg>
                            </div>
                            <div class="stat-number" id="activeStudents">523</div>
                            <div class="stat-label">Active Students</div>
                            <div class="stat-change">+48 this week</div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-icon">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                                    <line x1="16" y1="2" x2="16" y2="6"></line>
                                    <line x1="8" y1="2" x2="8" y2="6"></line>
                                    <line x1="3" y1="10" x2="21" y2="10"></line>
                                </svg>
                            </div>
                            <div class="stat-number" id="upcomingEvents">8</div>
                            <div class="stat-label">Upcoming Events</div>
                            <div class="stat-change">Next: Summer Camp</div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-icon">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M3 3v18h18"></path>
                                    <path d="M18.7 8l-5.1 5.2-2.8-2.7L7 14.3"></path>
                                </svg>
                            </div>
                            <div class="stat-number" id="growthRate">+24%</div>
                            <div class="stat-label">Growth Rate</div>
                            <div class="stat-change">Year over year</div>
                        </div>
                    </div>

                    <!-- Recent Activities -->
                    <div class="content-card">
                        <div class="card-header">
                            <h3>Recent Activities</h3>
                        </div>
                        <div class="card-content">
                            <div class="activity-list" id="recentActivities">
                                <!-- Activities will be loaded via JavaScript -->
                            </div>
                        </div>
                    </div>
                <% } else if (page === 'analytics') { %>
                    <div class="stats-grid">
                        <div class="stat-card"><div class="stat-icon">📊</div><div><div class="stat-number">96%</div><div class="stat-label">Platform Uptime</div></div></div>
                        <div class="stat-card"><div class="stat-icon">⏱</div><div><div class="stat-number">0.28s</div><div class="stat-label">Avg Response Time</div></div></div>
                        <div class="stat-card"><div class="stat-icon">📈</div><div><div class="stat-number">128</div><div class="stat-label">Reports Generated</div></div></div>
                        <div class="stat-card"><div class="stat-icon">💬</div><div><div class="stat-number">72</div><div class="stat-label">Active Communications</div></div></div>
                    </div>
                    <div class="content-card"><div class="card-header"><h3>Analytics Insights</h3></div><div class="card-content"><p>Real-time KPIs include staff productivity, school participation, and event engagement. Use this dashboard to identify bottlenecks and improve turn-around time for program booking.</p></div></div>
                <% } else if (page === 'staff') { %>
                    <div class="stats-grid">
                        <div class="stat-card"><div class="stat-icon">👥</div><div><div class="stat-number"><%= stats ? stats.totalStaff : 0 %></div><div class="stat-label">Total Staff</div></div></div>
                        <div class="stat-card"><div class="stat-icon">🟢</div><div><div class="stat-number"><%= stats ? stats.activeStaff : 0 %></div><div class="stat-label">Active Staff</div></div></div>
                        <div class="stat-card"><div class="stat-icon">🛑</div><div><div class="stat-number"><%= stats ? stats.onLeaveStaff : 0 %></div><div class="stat-label">On Leave</div></div></div>
                        <div class="stat-card"><div class="stat-icon">📊</div><div><div class="stat-number"><%= stats ? stats.avgAttendance : 0 %>%</div><div class="stat-label">Avg Attendance</div></div></div>
                    </div>
                    <div class="content-card">
                        <div class="card-header"><h3>Staff Directory</h3></div>
                        <div class="card-content">
                            <table class="data-table" id="staffTable">
                                <thead><tr><th>ID Number</th><th>Name
  <select id="staffSortOrder">
    <option value="asc">A-Z</option>
    <option value="desc">Z-A</option>
  </select></th><th>Email</th><th>Role</th><th>Status</th><th>Actions</th></tr></thead>
                                <tbody>
                                <% if (staffList && staffList.length > 0) { %>
                                    <% staffList.forEach(staff => { %>
                                        <tr>
                                            <td><%= staff.idNumber || '—' %></td>
                                            <td><%= staff.name %></td>
                                            <td><%= staff.email %></td>
                                            <td><%= staff.role %></td>
                                            <td><%= staff.status %></td>
                                            <td>
                                                <button type="button" class="btn btn-sm btn-outline" onclick="viewStaffProfile('<%= staff._id %>')">View Profile</button>
                                                <button type="button" class="btn btn-sm btn-outline" onclick="editStaff('<%= staff._id %>')">Edit</button>
                                                <button type="button" class="btn btn-sm btn-outline" onclick="deleteStaff('<%= staff._id %>')">Delete</button>
                                            </td>
                                        </tr>
                                    <% }) %>
                                <% } else { %>
                                    <tr><td colspan="6" class="placeholder-text">No staff entries found yet.</td></tr>
                                <% } %>
                            </tbody>
                            </table>
                        </div>
                    </div>
                    <div class="content-card">
                        <div class="card-header"><h3>Add New Staff Member</h3></div>
                        <div class="card-content">
                            <form action="/dashboard/staff/add" method="POST" class="form-grid">
                                <!-- Basic Information -->
                                <label>ID Number<input type="text" name="idNumber" placeholder="Optional staff ID"></label>
                                <label>Name<input type="text" name="name" required></label>
                                <label>Email<input type="email" name="email" required></label>
                                <label>Phone<input type="tel" name="phone"></label>
                                <label>Role<select name="role" required>
                                    <option value="">Select Role</option>
                                    <option value="trainer">Trainer</option>
                                    <option value="senior trainer">Senior Trainer</option>
                                    <option value="supervisor">Supervisor</option>
                                    <option value="admin">Admin</option>
                                    <option value="coordinator">Coordinator</option>
                                </select></label>
                                <label>Department<input type="text" name="department" value="Training"></label>
                                <label>Status<select name="status">
                                    <option value="Active">Active</option>
                                    <option value="On Leave">On Leave</option>
                                    <option value="Inactive">Inactive</option>
                                    <option value="Suspended">Suspended</option>
                                </select></label>

                                <!-- Address Information -->
                                <label>Street Address<input type="text" name="street"></label>
                                <label>City<input type="text" name="city"></label>
                                <label>State<input type="text" name="state"></label>
                                <label>Zip Code<input type="text" name="zipCode"></label>
                                <label>Country<input type="text" name="country" value="Kenya"></label>

                                <!-- Emergency Contact -->
                                <label>Emergency Contact Name<input type="text" name="emergencyContactName"></label>
                                <label>Emergency Contact Relationship<input type="text" name="emergencyContactRelationship"></label>
                                <label>Emergency Contact Phone<input type="tel" name="emergencyContactPhone"></label>
                                <label>Emergency Contact Email<input type="email" name="emergencyContactEmail"></label>

                                <div class="form-actions">
                                    <button type="submit" class="btn btn-primary">Add Staff & Send Invitation</button>
                                </div>
                            </form>
                        </div>
                    </div>

                    <!-- Edit Staff Modal -->
                    <div id="editStaffModal" class="modal" style="display: none;">
                        <div class="modal-content">
                            <div class="modal-header">
                                <h3>Edit Staff Member</h3>
                                <button type="button" class="close-btn" onclick="closeEditStaffModal()">×</button>
                            </div>
                            <div class="modal-body">
                                <form id="editStaffForm" class="form-grid">
                                    <input type="hidden" id="editStaffId" name="staffId">

                                    <!-- Basic Information -->
                                    <label>ID Number<input type="text" id="editIdNumber" name="idNumber"></label>
                                    <label>Name<input type="text" id="editName" name="name" required></label>
                                    <label>Email<input type="email" id="editEmail" name="email" required></label>
                                    <label>Phone<input type="tel" id="editPhone" name="phone"></label>
                                    <label>Role<select id="editRole" name="role" required>
                                        <option value="">Select Role</option>
                                        <option value="trainer">Trainer</option>
                                        <option value="senior trainer">Senior Trainer</option>
                                        <option value="supervisor">Supervisor</option>
                                        <option value="admin">Admin</option>
                                        <option value="coordinator">Coordinator</option>
                                    </select></label>
                                    <label>Department<input type="text" id="editDepartment" name="department"></label>
                                    <label>Status<select id="editStatus" name="status">
                                        <option value="Active">Active</option>
                                        <option value="On Leave">On Leave</option>
                                        <option value="Inactive">Inactive</option>
                                        <option value="Suspended">Suspended</option>
                                    </select></label>

                                    <!-- Address Information -->
                                    <label>Street Address<input type="text" id="editStreet" name="street"></label>
                                    <label>City<input type="text" id="editCity" name="city"></label>
                                    <label>State<input type="text" id="editState" name="state"></label>
                                    <label>Zip Code<input type="text" id="editZipCode" name="zipCode"></label>
                                    <label>Country<input type="text" id="editCountry" name="country"></label>

                                    <!-- Emergency Contact -->
                                    <label>Emergency Contact Name<input type="text" id="editEmergencyContactName" name="emergencyContactName"></label>
                                    <label>Emergency Contact Relationship<input type="text" id="editEmergencyContactRelationship" name="emergencyContactRelationship"></label>
                                    <label>Emergency Contact Phone<input type="tel" id="editEmergencyContactPhone" name="emergencyContactPhone"></label>
                                    <label>Emergency Contact Email<input type="email" id="editEmergencyContactEmail" name="emergencyContactEmail"></label>

                                    <!-- Permissions -->
                                    <div style="grid-column: 1 / -1; margin-top: 1rem;">
                                        <h4>Permissions</h4>
                                        <div class="permissions-grid">
                                            <label><input type="checkbox" id="editCanViewFinancials" name="canViewFinancials"> View Financials</label>
                                            <label><input type="checkbox" id="editCanApproveReports" name="canApproveReports"> Approve Reports</label>
                                            <label><input type="checkbox" id="editCanScheduleEvents" name="canScheduleEvents"> Schedule Events</label>
                                            <label><input type="checkbox" id="editCanManageStaff" name="canManageStaff"> Manage Staff</label>
                                            <label><input type="checkbox" id="editCanViewAnalytics" name="canViewAnalytics"> View Analytics</label>
                                            <label><input type="checkbox" id="editCanManageSchools" name="canManageSchools"> Manage Schools</label>
                                            <label><input type="checkbox" id="editCanSendInvitations" name="canSendInvitations"> Send Invitations</label>
                                        </div>
                                    </div>

                                    <!-- Performance Metrics Admin Input -->
                                    <div style="grid-column: 1 / -1; margin-top: 1rem;">
                                        <h4>Performance Metrics</h4>
                                        <div class="form-grid" style="grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 1rem;">
                                            <label>Events Completed<input type="number" id="editEventsCompleted" name="eventsCompleted" min="0" value="0"></label>
                                            <label>Reports Submitted<input type="number" id="editReportsSubmitted" name="reportsSubmitted" min="0" value="0"></label>
                                            <label>Schools Visited<input type="number" id="editSchoolsVisited" name="schoolsVisited" min="0" value="0"></label>
                                            <label>Avg Attendance (%)<input type="number" id="editAverageAttendanceRate" name="averageAttendanceRate" min="0" max="100" step="0.1"></label>
                                            <label>Avg Feedback Rating<input type="number" id="editAverageFeedbackRating" name="averageFeedbackRating" min="0" max="5" step="0.1"></label>
                                            <label>Last Review Date<input type="date" id="editLastPerformanceReview" name="lastPerformanceReview"></label>
                                        </div>
                                    </div>

                                    <div id="editMessage" class="message" style="display: none; grid-column: 1 / -1; margin-top: 1rem;"></div>
                                </form>
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-secondary" onclick="closeEditStaffModal()">Cancel</button>
                                <button type="button" class="btn btn-primary" onclick="saveEditStaff()">Save Changes</button>
                            </div>
                        </div>
                    </div>

                    <!-- Staff Profile Modal -->
                    <div id="staffProfileModal" class="modal" style="display: none;">
                        <div class="modal-content large-modal">
