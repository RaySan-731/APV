                                        <th>Type</th>
                                        <th>Dates</th>
                                        <th>Location</th>
                                        <th>Status</th>
                                        <th>Trainers</th>
                                        <th>RSVP</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody id="eventsTableBody">
                                    <!-- Events loaded via JS -->
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <!-- Calendar View (Month/Week/List) -->
                    <div id="calendarView" class="content-card" style="display: none;">
                        <div class="card-header">
                            <div style="display: flex; justify-content: space-between; align-items: center;">
                                <div style="display: flex; gap: 0.5rem; align-items: center;">
                                    <button class="btn btn-secondary" id="prevPeriodBtn">&lt; Previous</button>
                                    <h3 id="calendarTitle">Calendar View</h3>
                                    <button class="btn btn-secondary" id="nextPeriodBtn">Next &gt;</button>
                                </div>
                                <div style="display: flex; gap: 0.5rem;">
                                    <select id="calendarViewType" class="btn btn-secondary">
                                        <option value="month">Month</option>
                                        <option value="week">Week</option>
                                        <option value="list">List</option>
                                    </select>
                                    <a href="/api/calendar/export?startDate=<%= new Date().toISOString().split('T')[0] %>&endDate=<%= new Date(Date.now() + 90*24*60*60*1000).toISOString().split('T')[0] %>" class="btn btn-outline" target="_blank">Export CSV</a>
                                </div>
                            </div>
                        </div>
                        <div class="card-content" id="calendarContainer">
                            <!-- Calendar rendered via JS -->
                        </div>
                    </div>

                    <!-- Create/Edit Event Modal -->
                    <div id="eventModal" class="modal" style="display: none;">
                        <div class="modal-content large-modal">
                            <div class="modal-header">
                                <h3 id="eventModalTitle">Create New Event</h3>
                                <button type="button" class="close-btn" onclick="closeEventModal()">×</button>
                            </div>
                            <div class="modal-body">
                                <form id="eventForm" class="form-grid">
                                    <input type="hidden" id="eventId" name="eventId">

                                    <!-- Basic Info -->
                                    <div style="grid-column: 1 / -1; margin-bottom: 0.5rem; border-bottom: 1px solid var(--border); padding-bottom: 0.5rem;">
                                        <h4 style="margin:0;">Basic Information</h4>
                                    </div>
                                    <label>Event Name*<input type="text" name="name" id="eventName" required></label>
                                    <label>Event Type*<select name="eventType" id="eventType" required>
                                        <option value="camp">Camp</option>
                                        <option value="hike">Hike</option>
                                        <option value="team_building">Team Building</option>
                                        <option value="training_session">Training Session</option>
                                        <option value="inter_school_competition">Inter-School Competition</option>
                                        <option value="other">Other</option>
                                    </select></label>
                                    <label style="grid-column: 1 / -1;">Description<textarea name="description" id="eventDescription" rows="3"></textarea></label>
                                    <label style="grid-column: 1 / -1;">Agenda<textarea name="agenda" id="eventAgenda" rows="3"></textarea></label>

                                    <!-- Schedule -->
                                    <div style="grid-column: 1 / -1; margin-bottom: 0.5rem; border-bottom: 1px solid var(--border); padding-bottom: 0.5rem;">
                                        <h4 style="margin:0;">Schedule</h4>
                                    </div>
                                    <label>Start Date*<input type="datetime-local" name="startDate" id="eventStartDate" required></label>
                                    <label>End Date*<input type="datetime-local" name="endDate" id="eventEndDate" required></label>
                                    <label>Registration Deadline<input type="datetime-local" name="registrationDeadline" id="eventRegistrationDeadline"></label>
                                    <label>Default RSVP Deadline for Invitations<input type="datetime-local" name="defaultInvitationDeadline" id="eventDefaultRsvpDeadline"></label>

                                    <!-- Location -->
                                    <div style="grid-column: 1 / -1; margin-bottom: 0.5rem; border-bottom: 1px solid var(--border); padding-bottom: 0.5rem;">
                                        <h4 style="margin:0;">Location</h4>
                                    </div>
                                    <label>Location Name*<input type="text" name="locationName" id="locationName" required></label>
                                    <label>Address<input type="text" name="locationAddress" id="locationAddress"></label>
                                    <label>City<input type="text" name="locationCity" id="locationCity"></label>
                                    <label>Region<input type="text" name="locationRegion" id="locationRegion" placeholder="e.g., Nairobi, Coast"></label>
                                    <label>Country<input type="text" name="locationCountry" id="locationCountry" value="Kenya"></label>
                                    <label style="grid-column: 1 / -1;">Coordinates (lat, lng)<input type="text" name="coordinates" id="coordinates" placeholder="e.g., -1.2921, 36.8219"></label>

                                    <!-- Capacity & Participants -->
                                    <div style="grid-column: 1 / -1; margin-bottom: 0.5rem; border-bottom: 1px solid var(--border); padding-bottom: 0.5rem;">
                                        <h4 style="margin:0;">Capacity</h4>
                                    </div>
                                    <label>Max Participants*<input type="number" name="maxParticipants" id="maxParticipants" min="1" required></label>
                                    <label>Estimated Scout Count<input type="number" name="estimatedScoutCount" id="estimatedScoutCount" min="0"></label>
                                    <label>
                                        <input type="checkbox" name="waitlistEnabled" id="waitlistEnabled">
                                        Enable Waitlist
                                    </label>

                                    <!-- Equipment -->
                                    <div style="grid-column: 1 / -1; margin-bottom: 0.5rem; border-bottom: 1px solid var(--border); padding-bottom: 0.5rem;">
                                        <h4 style="margin:0;">Required Equipment</h4>
                                    </div>
                                    <label style="grid-column: 1 / -1;">
                                        <div id="equipmentList">
                                            <!-- Dynamic equipment list -->
                                        </div>
                                        <button type="button" class="btn btn-secondary" onclick="addEquipmentItem()">+ Add Equipment</button>
                                    </label>

                                    <!-- Prerequisites -->
                                    <div style="grid-column: 1 / -1; margin-bottom: 0.5rem; border-bottom: 1px solid var(--border); padding-bottom: 0.5rem;">
                                        <h4 style="margin:0;">Prerequisites (optional)</h4>
                                    </div>
                                    <label style="grid-column: 1 / -1;">
                                        <div id="prerequisitesList">
                                            <!-- Dynamic prerequisites -->
                                        </div>
                                        <button type="button" class="btn btn-secondary" onclick="addPrerequisite()">+ Add Prerequisite</button>
                                    </label>

                                    <!-- Budget -->
                                    <div style="grid-column: 1 / -1; margin-bottom: 0.5rem; border-bottom: 1px solid var(--border); padding-bottom: 0.5rem;">
                                        <h4 style="margin:0;">Budget</h4>
                                    </div>
                                    <label>Total Budget (KES)<input type="number" name="budgetTotal" id="budgetTotal" min="0" step="0.01"></label>
                                    <label>Cost Per Participant (KES)<input type="number" name="costPerParticipant" id="costPerParticipant" min="0" step="0.01"></label>

                                    <!-- Publishing -->
                                    <div style="grid-column: 1 / -1; margin-bottom: 0.5rem; border-bottom: 1px solid var(--border); padding-bottom: 0.5rem;">
                                        <h4 style="margin:0;">Publishing</h4>
                                    </div>
                                    <label>Status<select name="status" id="eventStatus">
                                        <option value="draft">Draft</option>
                                        <option value="scheduled">Scheduled</option>
                                        <option value="confirmed">Confirmed</option>
                                        <option value="in_progress">In Progress</option>
                                        <option value="completed">Completed</option>
                                        <option value="reviewed">Reviewed</option>
                                        <option value="cancelled">Cancelled</option>
                                        <option value="archived">Archived</option>
                                    </select></label>
                                    <label>Visibility<select name="visibility" id="eventVisibility">
                                        <option value="private">Private</option>
                                        <option value="public">Public</option>
                                        <option value="invited_only">Invited Only</option>
                                    </select></label>

                                    <div class="form-actions" style="grid-column: 1 / -1;">
                                        <button type="button" class="btn btn-secondary" onclick="closeEventModal()">Cancel</button>
                                        <button type="submit" class="btn btn-primary" id="saveEventBtn">Create Event</button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>

                    <!-- Manage Event Details Modal (assign trainers, invite schools, view RSVPs) -->
<div id="manageEventModal" class="modal" style="display: none;">
    <div class="modal-content large-modal">
        <div class="modal-header">
            <h3 id="manageEventTitle">Manage Event</h3>
            <button type="button" class="close-btn" onclick="closeManageEventModal()">×</button>
        </div>
        <div class="modal-body">
            <input type="hidden" id="manageEventId">
            <div style="display: flex; flex-direction: column; gap: 1.5rem;">
                                    <!-- Trainer Assignment Section -->
                                    <div class="manage-section">
                                        <h4>Trainer Assignments</h4>
                                        <div id="assignedTrainersList" style="margin-bottom: 1rem;"></div>
                                        <div style="display: flex; gap: 0.5rem; flex-wrap: wrap; align-items: flex-end;">
                                            <select id="trainerSelect" style="padding: 0.5rem; border: 1px solid var(--border); border-radius: var(--radius); min-width: 200px;">
                                                <option value="">Select a trainer...</option>
                                            </select>
                                            <select id="trainerRoleSelect" style="padding: 0.5rem; border: 1px solid var(--border); border-radius: var(--radius);">
                                                <option value="lead_trainer">Lead Trainer</option>
                                                <option value="assistant_trainer">Assistant Trainer</option>
                                                <option value="coordinator">Coordinator</option>
                                                <option value="volunteer">Volunteer</option>
                                            </select>
                                            <button class="btn btn-primary" onclick="assignTrainer()">Assign Trainer</button>
                                        </div>
                                        <div id="trainerConflictError" class="message" style="display: none; margin-top: 0.5rem;"></div>
                                    </div>

                                    <!-- School Invitations Section -->
                                    <div class="manage-section">
                                        <h4>School Invitations</h4>
                                        <div id="invitedSchoolsList" style="margin-bottom: 1rem; max-height: 200px; overflow-y: auto;"></div>
                                        <div style="display: flex; gap: 0.5rem; flex-wrap: wrap; align-items: flex-end;">
                                            <select id="schoolSelect" style="padding: 0.5rem; border: 1px solid var(--border); border-radius: var(--radius); min-width: 200px;">
                                                <option value="">Select a school...</option>
                                            </select>
                                            <label style="display: flex; align-items: center; gap: 0.5rem;">RSVP Deadline<input type="date" id="inviteRsvpDeadline"></label>
                                            <button class="btn btn-primary" onclick="inviteSchool()">Send Invitation</button>
                                        </div>
                                    </div>

                                    <!-- Invitation Reminders -->
                                    <div class="manage-section">
                                        <h4>Send Reminders</h4>
                                        <p style="font-size: 0.875rem; color: var(--muted-foreground);">Send automated reminders to schools that haven't responded.</p>
                                        <div style="display: flex; gap: 0.5rem;">
                                            <button class="btn btn-secondary" onclick="sendReminders('3d')">Remind in 3 days</button>
                                            <button class="btn btn-secondary" onclick="sendReminders('1w')">Remind in 1 week</button>
                                            <button class="btn btn-secondary" onclick="sendReminders('overdue')">Remind Overdue</button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                 <% } else if (page === 'programs') { %>
                    <div class="stats-grid">
                        <div class="stat-card"><div class="stat-icon">📚</div><div><div class="stat-number">28</div><div class="stat-label">Program Offerings</div></div></div>
                        <div class="stat-card"><div class="stat-icon">🏕</div><div><div class="stat-number">9</div><div class="stat-label">Live Programs</div></div></div>
                        <div class="stat-card"><div class="stat-icon">🕒</div><div><div class="stat-number">12</div><div class="stat-label">Upcoming Starts</div></div></div>
                        <div class="stat-card"><div class="stat-icon">🧾</div><div><div class="stat-number">5</div><div class="stat-label">New Proposals</div></div></div>
                    </div>
                    <div class="content-card">
                        <div class="card-header"><h3>Program Catalog</h3></div>
                        <div class="card-content">
                            <table class="data-table">
                                <thead><tr><th>Name</th><th>Category</th><th>Duration</th><th>Enrollment</th><th>Status</th></tr></thead>
                                <tbody>
                                    <% if (programList && programList.length > 0) { %>
                                        <% programList.forEach(program => { %>
                                            <tr>
                                                <td><%= program.name %></td>
                                                <td><%= program.category %></td>
                                                <td><%= program.duration %></td>
                                                <td><%= program.maxParticipants %></td>
                                                <td><%= program.status %></td>
                                            </tr>
                                        <% }) %>
                                    <% } else { %>
                                        <tr><td colspan="5" class="placeholder-text">No programs available yet.</td></tr>
                                    <% } %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                    <div class="content-card">
                        <div class="card-header"><h3>Add Program</h3></div>
                        <div class="card-content">
                            <form action="/dashboard/programs/add" method="POST" class="form-grid">
                                <label>Name<input type="text" name="name" required></label>
                                <label>Description<textarea name="description" rows="2" required></textarea></label>
                                <label>Category<select name="category" required><option value="leadership">Leadership</option><option value="outdoor">Outdoor</option><option value="team-building">Team Building</option><option value="first-aid">First Aid</option><option value="environmental">Environmental</option><option value="community-service">Community Service</option></select></label>
                                <label>Age Min<input type="number" name="ageMin" min="5" max="18" value="8"></label>
                                <label>Age Max<input type="number" name="ageMax" min="5" max="18" value="16"></label>
                                <label>Duration<select name="duration"><option value="half-day">Half Day</option><option value="full-day">Full Day</option><option value="weekend">Weekend</option><option value="week">Week</option><option value="month">Month</option></select></label>
                                <label>Max Participants<input type="number" name="maxParticipants" min="1" value="10"></label>
                                <label>Price Amount<input type="number" step="0.01" name="priceAmount" min="0" value="0"></label>
                                <label>Price Currency<input type="text" name="priceCurrency" value="USD"></label>
                                <label>Status<select name="status"><option value="active">Active</option><option value="inactive">Inactive</option><option value="draft">Draft</option></select></label>
                                <button type="submit" class="btn btn-primary">Add Program</button>
                            </form>
                        </div>
                    </div>
                <% } else if (page === 'trainers') { %>
                    <% 
                        let totalTrainers = trainersList ? trainersList.length : 0;
                        let activeTrainers = trainersList ? trainersList.filter(t => t.status === 'Active').length : 0;
                        let onLeaveTrainers = trainersList ? trainersList.filter(t => t.status === 'On Leave').length : 0;
                        let certifiedTrainers = Math.floor(totalTrainers * 0.75); // Placeholder calculation
                    %>
                    <div class="stats-grid">
                        <div class="stat-card"><div class="stat-icon">👨‍🏫</div><div><div class="stat-number"><%= totalTrainers %></div><div class="stat-label">Total Trainers</div></div></div>
                        <div class="stat-card"><div class="stat-icon">🟢</div><div><div class="stat-number"><%= activeTrainers %></div><div class="stat-label">Active Trainers</div></div></div>
                        <div class="stat-card"><div class="stat-icon">⭐</div><div><div class="stat-number"><%= totalTrainers > 0 ? ((activeTrainers / totalTrainers * 100).toFixed(0) + '%') : '0%' %></div><div class="stat-label">Active Rate</div></div></div>
                        <div class="stat-card"><div class="stat-icon">📊</div><div><div class="stat-number"><%= onLeaveTrainers %></div><div class="stat-label">On Leave</div></div></div>
                    </div>
                    <div class="content-card">
                        <div class="card-header">
                            <h3>Trainers Directory</h3>
                        </div>
                        <div class="card-content">
                            <table class="data-table">
                                <thead><tr><th>ID Number</th><th>Name</th><th>Email</th><th>Phone</th><th>Status</th><th>Actions</th></tr></thead>
                                <tbody>
                                <% if (trainersList && trainersList.length > 0) { %>
                                    <% trainersList.forEach(trainer => { %>
                                        <tr>
                                            <td><%= trainer.idNumber || '—' %></td>
                                            <td><%= trainer.name %></td>
                                            <td><%= trainer.email %></td>
                                            <td><%= trainer.phone || '—' %></td>
                                            <td><span class="badge badge-<%= trainer.status === 'Active' ? 'success' : trainer.status === 'On Leave' ? 'warning' : 'danger' %>"><%= trainer.status %></span></td>
                                            <td>
                                                <button type="button" class="btn btn-sm btn-outline" onclick="editTrainer('<%= trainer._id %>')">Edit</button>
                                                <button type="button" class="btn btn-sm btn-outline" onclick="openAllocateSchoolsModal('<%= trainer._id %>')">Allocate Schools</button>
                                                <button type="button" class="btn btn-sm btn-outline" onclick="deleteTrainer('<%= trainer._id %>')">Delete</button>
                                            </td>
                                        </tr>
                                    <% }) %>
                                <% } else { %>
                                    <tr><td colspan="6" class="placeholder-text">No trainers found. Add one to get started!</td></tr>
                                <% } %>
                            </tbody>
                            </table>
                        </div>
                    </div>
                    <div class="content-card">
                        <div class="card-header">
                            <h3>Add New Trainer</h3>
                        </div>
                        <div class="card-content">
                            <form action="/dashboard/trainer/add" method="POST" class="form-grid">
                                <label>ID Number<input type="text" name="idNumber" placeholder="e.g., TRN001"></label>
                                <label>Name<input type="text" name="name" required placeholder="Full Name"></label>
                                <label>Email<input type="email" name="email" required placeholder="trainer@example.com"></label>
                                <label>Phone<input type="tel" name="phone" placeholder="+254712345678"></label>
                                <label>Status<select name="status" required>
                                    <option value="">Select Status</option>
                                    <option value="Active">Active</option>
                                    <option value="On Leave">On Leave</option>
                                    <option value="Inactive">Inactive</option>
                                </select></label>
                                <label>Password<input type="password" name="password" required placeholder="Set initial password"></label>
                                <button type="submit" class="btn btn-primary">Add Trainer</button>
                            </form>
                        </div>
                    </div>

                    <!-- Edit Trainer Modal -->
                    <div id="editTrainerModal" class="modal" style="display: none;">
