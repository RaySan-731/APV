<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard - Arrow-Park Ventures</title>
    <link rel="stylesheet" href="/css/styles.css">
    <link rel="icon" href="/favicon.ico">
</head>
<body>
    <div class="dashboard-layout">
        <!-- Sidebar -->
        <aside class="sidebar" id="sidebar">
            <div class="sidebar-header">
                <div class="sidebar-brand">
                    <svg class="sidebar-logo" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M17 14V2"></path>
                        <path d="M9 18.12L10 14H4l1.88-4.12L9 18.12z"></path>
                        <path d="M13 22l3-8"></path>
                        <path d="M7 22l3-8"></path>
                    </svg>
                    <span>Arrow-Park Ventures</span>
                </div>
                <button class="sidebar-toggle" id="sidebarToggle">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M3 12h18"></path>
                        <path d="M3 6h18"></path>
                        <path d="M3 18h18"></path>
                    </svg>
                </button>
            </div>

            <nav class="sidebar-nav">
                <div class="nav-section">
                    <h3 class="nav-section-title">Main Menu</h3>
                    <ul class="nav-list">
                        <li class="nav-item">
                            <a href="/dashboard" class="nav-link <%= page === 'dashboard' ? 'active' : '' %>">
                                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
                                    <polyline points="9,22 9,12 15,12 15,22"></polyline>
                                </svg>
                                Dashboard
                            </a>
                        </li>
                        <li class="nav-item">
                            <a href="/dashboard/analytics" class="nav-link <%= page === 'analytics' ? 'active' : '' %>">
                                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M3 3v18h18"></path>
                                    <path d="M18.7 8l-5.1 5.2-2.8-2.7L7 14.3"></path>
                                </svg>
                                Analytics
                            </a>
                        </li>
                        <li class="nav-item">
                            <a href="/dashboard/staff" class="nav-link <%= page === 'staff' ? 'active' : '' %>">
                                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                                    <circle cx="9" cy="7" r="4"></circle>
                                    <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
                                    <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
                                </svg>
                                Staff Management
                            </a>
                        </li>
                        <li class="nav-item">
                            <a href="/dashboard/schools" class="nav-link <%= page === 'schools' ? 'active' : '' %>">
                                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M12 2l3 3 3-3v8a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2V2l3 3 3-3z"></path>
                                    <path d="M2 12h20"></path>
                                    <path d="M6 12v8"></path>
                                    <path d="M18 12v8"></path>
                                </svg>
                                Schools
                            </a>
                        </li>
                        <li class="nav-item">
                            <a href="/dashboard/events" class="nav-link <%= page === 'events' ? 'active' : '' %>">
                                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                                    <line x1="16" y1="2" x2="16" y2="6"></line>
                                    <line x1="8" y1="2" x2="8" y2="6"></line>
                                    <line x1="3" y1="10" x2="21" y2="10"></line>
                                </svg>
                                Events
                            </a>
                        </li>
                        <li class="nav-item">
                            <a href="/dashboard/programs" class="nav-link <%= page === 'programs' ? 'active' : '' %>">
                                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                                    <polyline points="14,2 14,8 20,8"></polyline>
                                    <line x1="16" y1="13" x2="8" y2="13"></line>
                                    <line x1="16" y1="17" x2="8" y2="17"></line>
                                    <polyline points="10,9 9,9 8,9"></polyline>
                                </svg>
                                Programs
                            </a>
                        </li>
                        <li class="nav-item">
                            <a href="/dashboard/settings" class="nav-link <%= page === 'settings' ? 'active' : '' %>">
                                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <circle cx="12" cy="12" r="3"></circle>
                                    <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1 1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"></path>
                                </svg>
                                Settings
                            </a>
                        </li>
                    </ul>
                </div>

                <div class="nav-section">
                    <h3 class="nav-section-title">Support</h3>
                    <ul class="nav-list">
                        <li class="nav-item">
                            <a href="/help" class="nav-link">
                                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <circle cx="12" cy="12" r="10"></circle>
                                    <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"></path>
                                    <path d="M12 17h.01"></path>
                                </svg>
                                Help & FAQ
                            </a>
                        </li>
                    </ul>
                </div>
            </nav>

            <div class="sidebar-footer">
                <a href="/logout" class="logout-btn">
                    <svg class="logout-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
                        <polyline points="16,17 21,12 16,7"></polyline>
                        <line x1="21" y1="12" x2="9" y2="12"></line>
                    </svg>
                    Logout
                </a>
            </div>
        </aside>

        <!-- Main Content -->
        <main class="main-content">
            <header class="dashboard-header">
                <button class="mobile-sidebar-toggle" id="mobileSidebarToggle">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M3 12h18"></path>
                        <path d="M3 6h18"></path>
                        <path d="M3 18h18"></path>
                    </svg>
                </button>
                <h1 class="page-title">
                    <% if (page === 'dashboard') { %>Dashboard<% } %>
                    <% if (page === 'analytics') { %>Analytics<% } %>
                    <% if (page === 'staff') { %>Staff Management<% } %>
                    <% if (page === 'schools') { %>Schools<% } %>
                    <% if (page === 'events') { %>Events<% } %>
                    <% if (page === 'programs') { %>Programs<% } %>
                    <% if (page === 'settings') { %>Settings<% } %>
                    <% if (page === 'trainers') { %>Trainers<% } %>
                    <% if (page === 'schedule') { %>Training Schedule<% } %>
                    <% if (page === 'health') { %>Health Records<% } %>
                </h1>
                <div class="user-info">
                    <span>Welcome, <%= user.name %></span>
                </div>
            </header>

            <div class="dashboard-content">
                <% if (page === 'dashboard') { %>
                    <!-- Dashboard Stats -->
                    <div class="stats-grid">
                        <div class="stat-card">
                            <div class="stat-icon">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M12 2l3 3 3-3v8a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2V2l3 3 3-3z"></path>
                                    <path d="M2 12h20"></path>
                                    <path d="M6 12v8"></path>
                                    <path d="M18 12v8"></path>
                                </svg>
                            </div>
                            <div class="stat-number" id="totalSchools">25</div>
                            <div class="stat-label">Total Schools</div>
                            <div class="stat-change">+3 this month</div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-icon">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                                    <circle cx="9" cy="7" r="4"></circle>
                                    <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
                                    <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
                                </svg>
                            </div>
                            <div class="stat-number" id="activeStudents">523</div>
                            <div class="stat-label">Active Students</div>
                            <div class="stat-change">+48 this week</div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-icon">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                                    <line x1="16" y1="2" x2="16" y2="6"></line>
                                    <line x1="8" y1="2" x2="8" y2="6"></line>
                                    <line x1="3" y1="10" x2="21" y2="10"></line>
                                </svg>
                            </div>
                            <div class="stat-number" id="upcomingEvents">8</div>
                            <div class="stat-label">Upcoming Events</div>
                            <div class="stat-change">Next: Summer Camp</div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-icon">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M3 3v18h18"></path>
                                    <path d="M18.7 8l-5.1 5.2-2.8-2.7L7 14.3"></path>
                                </svg>
                            </div>
                            <div class="stat-number" id="growthRate">+24%</div>
                            <div class="stat-label">Growth Rate</div>
                            <div class="stat-change">Year over year</div>
                        </div>
                    </div>

                    <!-- Recent Activities -->
                    <div class="content-card">
                        <div class="card-header">
                            <h3>Recent Activities</h3>
                        </div>
                        <div class="card-content">
                            <div class="activity-list" id="recentActivities">
                                <!-- Activities will be loaded via JavaScript -->
                            </div>
                        </div>
                    </div>
                <% } else { %>
                    <!-- Placeholder content for other pages -->
                    <div class="content-card">
                        <div class="card-header">
                            <h3>
                                <% if (page === 'analytics') { %>Analytics Overview<% } %>
                                <% if (page === 'staff') { %>Staff Management<% } %>
                                <% if (page === 'schools') { %>Schools<% } %>
                                <% if (page === 'events') { %>Events<% } %>
                                <% if (page === 'programs') { %>Programs<% } %>
                                <% if (page === 'settings') { %>Settings<% } %>
                                <% if (page === 'trainers') { %>Trainers<% } %>
                                <% if (page === 'schedule') { %>Training Schedule<% } %>
                                <% if (page === 'health') { %>Health Records<% } %>
                            </h3>
                        </div>
                        <div class="card-content">
                            <p class="placeholder-text">
                                <% if (page === 'analytics') { %>Analytics dashboard content will be displayed here.<% } %>
                                <% if (page === 'staff') { %>Staff management interface will be displayed here.<% } %>
                                <% if (page === 'schools') { %>School management interface will be displayed here.<% } %>
                                <% if (page === 'events') { %>Events management interface will be displayed here.<% } %>
                                <% if (page === 'programs') { %>Programs management interface will be displayed here.<% } %>
                                <% if (page === 'settings') { %>Application settings will be displayed here.<% } %>
                                <% if (page === 'trainers') { %>Trainers management interface will be displayed here.<% } %>
                                <% if (page === 'schedule') { %>Training schedule will be displayed here.<% } %>
                                <% if (page === 'health') { %>Health records will be displayed here.<% } %>
                            </p>
                        </div>
                    </div>
                <% } %>
            </div>
        </main>
    </div>

    <script src="/js/dashboard.js"></script>
</body>
</html>