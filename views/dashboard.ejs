                                <button type="button" class="close-btn" onclick="closeStaffProfileModal()">×</button>
                            </div>
                            <div class="modal-body">
                                <div class="profile-sections">
                                    <!-- Basic Information -->
                                    <div class="profile-section">
                                        <h4>Basic Information</h4>
                                        <div class="profile-grid">
                                            <div class="profile-field"><strong>ID Number:</strong> <span id="profileIdNumber">—</span></div>
                                            <div class="profile-field"><strong>Name:</strong> <span id="profileName">—</span></div>
                                            <div class="profile-field"><strong>Email:</strong> <span id="profileEmail">—</span></div>
                                            <div class="profile-field"><strong>Phone:</strong> <span id="profilePhone">—</span></div>
                                            <div class="profile-field"><strong>Role:</strong> <span id="profileRole">—</span></div>
                                            <div class="profile-field"><strong>Status:</strong> <span id="profileStatus">—</span></div>
                                            <div class="profile-field"><strong>Department:</strong> <span id="profileDepartment">—</span></div>
                                            <div class="profile-field"><strong>Start Date:</strong> <span id="profileStartDate">—</span></div>
                                        </div>
                                    </div>

                                    <!-- Address Information -->
                                    <div class="profile-section">
                                        <h4>Address</h4>
                                        <div class="profile-grid">
                                            <div class="profile-field"><strong>Street:</strong> <span id="profileStreet">—</span></div>
                                            <div class="profile-field"><strong>City:</strong> <span id="profileCity">—</span></div>
                                            <div class="profile-field"><strong>State:</strong> <span id="profileState">—</span></div>
                                            <div class="profile-field"><strong>Zip Code:</strong> <span id="profileZipCode">—</span></div>
                                            <div class="profile-field"><strong>Country:</strong> <span id="profileCountry">—</span></div>
                                        </div>
                                    </div>

                                    <!-- Emergency Contact -->
                                    <div class="profile-section">
                                        <h4>Emergency Contact</h4>
                                        <div class="profile-grid">
                                            <div class="profile-field"><strong>Name:</strong> <span id="profileEmergencyName">—</span></div>
                                            <div class="profile-field"><strong>Relationship:</strong> <span id="profileEmergencyRelationship">—</span></div>
                                            <div class="profile-field"><strong>Phone:</strong> <span id="profileEmergencyPhone">—</span></div>
                                            <div class="profile-field"><strong>Email:</strong> <span id="profileEmergencyEmail">—</span></div>
                                        </div>
                                    </div>

                                    <!-- Certifications -->
                                    <div class="profile-section">
                                        <h4>Certifications</h4>
                                        <div id="profileCertifications">
                                            <p class="placeholder-text">No certifications found.</p>
                                        </div>
                                    </div>

                                    <!-- Assigned Schools -->
                                    <div class="profile-section">
                                        <h4>Assigned Schools</h4>
                                        <div id="profileAssignedSchools">
                                            <p class="placeholder-text">No school assignments found.</p>
                                        </div>
                                    </div>

                                    <!-- Availability -->
                                    <div class="profile-section">
                                        <h4>Availability</h4>
                                        <div id="profileAvailability">
                                            <p class="placeholder-text">No availability data available.</p>
                                        </div>
                                    </div>

                                    <!-- Leave History -->
                                    <div class="profile-section">
                                        <h4>Leave History</h4>
                                        <div id="profileLeaveHistory">
                                            <p class="placeholder-text">No leave history found.</p>
                                        </div>
                                    </div>

                                    <!-- Performance Metrics -->
                                    <div class="profile-section">
                                        <h4>Performance Metrics</h4>
                                        <div class="profile-grid">
                                            <div class="profile-field"><strong>Events Completed:</strong> <span id="profileEventsCompleted">0</span></div>
                                            <div class="profile-field"><strong>Reports Submitted:</strong> <span id="profileReportsSubmitted">0</span></div>
                                            <div class="profile-field"><strong>Schools Visited:</strong> <span id="profileSchoolsVisited">0</span></div>
                                            <div class="profile-field"><strong>Avg Attendance Rate:</strong> <span id="profileAttendanceRate">0%</span></div>
                                            <div class="profile-field"><strong>Avg Feedback Rating:</strong> <span id="profileFeedbackRating">0</span></div>
                                            <div class="profile-field"><strong>Last Review:</strong> <span id="profileLastReview">—</span></div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-secondary" onclick="closeStaffProfileModal()">Close</button>
                            </div>
                        </div>
                    </div>
                <% } else if (page === 'schools') { %>
                    <!-- Schools Stats Grid -->
                    <div class="stats-grid">
                        <div class="stat-card">
                            <div class="stat-icon">🏫</div>
                            <div><div class="stat-number"><%= schoolList ? schoolList.length : 0 %></div><div class="stat-label">Partner Schools</div></div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-icon">👧</div>
                            <div><div class="stat-number"><%= schoolList ? (schoolList.reduce((sum, s) => sum + (s.studentCount || 0), 0)) : 0 %></div><div class="stat-label">Total Students</div></div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-icon">✅</div>
                            <div><div class="stat-number"><%= schoolList ? (schoolList.filter(s => s.serviceStatus === 'active').length) : 0 %></div><div class="stat-label">Active Service</div></div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-icon">⏸</div>
                            <div><div class="stat-number"><%= schoolList ? (schoolList.filter(s => s.serviceStatus === 'on_hold').length) : 0 %></div><div class="stat-label">On Hold</div></div>
                        </div>
                    </div>

                    <!-- Filters Bar -->
                    <div class="content-card">
                        <div class="card-header">
                            <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem;">
                                <h3>School Registry</h3>
                                <div style="display: flex; gap: 0.5rem; align-items: center;">
                                    <input type="text" id="schoolSearch" placeholder="Search schools..." value="<%= filters.search || '' %>" style="padding: 0.5rem; border: 1px solid var(--border); border-radius: var(--radius); width: 200px;">
                                    <select id="statusFilter" style="padding: 0.5rem; border: 1px solid var(--border); border-radius: var(--radius);">
                                        <option value="">All Status</option>
                                        <option value="active" <%= filters.status === 'active' ? 'selected' : '' %>>Active</option>
                                        <option value="inactive" <%= filters.status === 'inactive' ? 'selected' : '' %>>Inactive</option>
                                        <option value="pending" <%= filters.status === 'pending' ? 'selected' : '' %>>Pending</option>
                                    </select>
                                    <select id="serviceStatusFilter" style="padding: 0.5rem; border: 1px solid var(--border); border-radius: var(--radius);">
                                        <option value="">All Service Status</option>
                                        <option value="active" <%= filters.serviceStatus === 'active' ? 'selected' : '' %>>Active</option>
                                        <option value="on_hold" <%= filters.serviceStatus === 'on_hold' ? 'selected' : '' %>>On Hold</option>
                                        <option value="churned" <%= filters.serviceStatus === 'churned' ? 'selected' : '' %>>Churned</option>
                                    </select>
                                    <select id="zoneFilter" style="padding: 0.5rem; border: 1px solid var(--border); border-radius: var(--radius);">
                                        <option value="">All Zones</option>
                                        <% (schoolList || []).filter(s => s.zone).map(z => { %><option value="<%= z.zone %>" <%= filters.zone === z.zone ? 'selected' : '' %>><%= z.zone %></option><% }) %></select>
                                    <button class="btn btn-primary" onclick="window.DashboardUtils.openOnboardingModal()">+ Onboard New School</button>
                                </div>
                            </div>
                        </div>
                        <div class="card-content">
                            <table class="data-table" id="schoolsTable">
                                <thead>
                                    <tr>
                                        <th>School
                                            <select id="schoolSortOrder" style="margin-left: 0.5rem; font-size: 0.875rem;">
                                                <option value="asc" <%= sortBy === 'name' && order === 'asc' ? 'selected' : '' %>>A-Z</option>
                                                <option value="desc" <%= sortBy === 'name' && order === 'desc' ? 'selected' : '' %>>Z-A</option>
                                            </select>
                                        </th>
                                        <th>Location</th>
                                        <th>Zone</th>
                                        <th>Trainers</th>
                                        <th>Students</th>
                                        <th>Events</th>
                                        <th>Attendance</th>
                                        <th>Status</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% if (schoolList && schoolList.length > 0) { %>
                                        <% schoolList.forEach(school => { %>
                                            <tr>
                                                <td><strong><a href="/dashboard/schools/<%= school._id %>" style="color: var(--primary); text-decoration: none;"><%= school.name %></a></strong></td>
                                                <td><%= school.address && school.address.city ? school.address.city + (school.address.state ? ', ' + school.address.state : '') : '—' %></td>
                                                <td><%= school.zone || '—' %></td>
                                                <td>
                                                    <% if (school.assignedStaff && school.assignedStaff.length > 0) { %>
                                                        <div class="trainer-list" style="display: flex; flex-direction: column; gap: 0.25rem;">
                                                            <% school.assignedStaff.forEach(trainer => { %>
                                                                <div style="font-size: 0.8rem;">
                                                                    <strong><%= trainer.name || trainer.email %></strong>
                                                                </div>
                                                            <% }) %>
                                                        </div>
                                                    <% } else { %>
                                                        <span class="badge badge-warning">Unassigned</span>
                                                    <% } %>
                                                </td>
                                                <td><%= school.studentCount || 0 %></td>
                                                <td>
                                                    <span class="<%= school.participationMetrics && school.participationMetrics.totalEventsAttended > 5 ? 'badge badge-success' : 'badge badge-info' %>">
                                                        <%= school.participationMetrics ? school.participationMetrics.totalEventsAttended : 0 %>
                                                    </span>
                                                </td>
                                                <td>
                                                    <span class="<%= school.participationMetrics && school.participationMetrics.averageAttendanceRate >= 80 ? 'badge badge-success' : school.participationMetrics && school.participationMetrics.averageAttendanceRate >= 60 ? 'badge badge-warning' : 'badge badge-danger' %>">
                                                        <%= school.participationMetrics ? school.participationMetrics.averageAttendanceRate : 0 %>%
                                                    </span>
                                                </td>
                                                <td>
                                                    <span class="<%= school.serviceStatus === 'active' ? 'badge badge-success' : school.serviceStatus === 'on_hold' ? 'badge badge-warning' : 'badge badge-secondary' %>">
                                                        <%= school.serviceStatus ? school.serviceStatus.replace('_', ' ') : school.status %>
                                                    </span>
                                                </td>
                                                <td>
                                                    <button class="btn btn-sm btn-outline" onclick="window.location.href='/dashboard/schools/<%= school._id %>'">View Profile</button>
                                                    <button class="btn btn-sm btn-outline" onclick="window.location.href='/dashboard/schools/<%= school._id %>/edit'">Edit</button>
                                                </td>
                                            </tr>
                                        <% }) %>
                                    <% } else { %>
                                        <tr><td colspan="9" class="placeholder-text">No partner schools found. Try adjusting filters or <a href="/dashboard/schools/onboard">onboard a new school</a>.</td></tr>
                                    <% } %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                <% } else if (page === 'school-profile') { %>
                    <!-- Individual School Profile View -->
                    <button class="btn btn-secondary" onclick="window.location.href='/dashboard/schools'" style="margin-bottom: 1rem;">← Back to Schools</button>
                    
                    <!-- School Header -->
                    <div class="stats-grid">
                        <div class="stat-card" style="grid-column: span 3; padding: 1.5rem;">
                            <h2 style="margin: 0 0 0.5rem 0; color: var(--foreground);"><%= school.name %></h2>
                            <div style="display: flex; gap: 1.5rem; color: var(--muted-foreground); font-size: 0.9rem; flex-wrap: wrap;">
                                <span>📍 <%= school.address && school.address.city ? [school.address.city, school.address.state].filter(Boolean).join(', ') : 'Location not set' %></span>
                                <span>🏫 <%= school.studentCount || 0 %> Students</span>
                                <span>📅 Onboarded: <%= school.onboardingDate ? new Date(school.onboardingDate).toLocaleDateString() : '—' %></span>
                                <span>📞 <%= school.contactPerson && school.contactPerson.phone ? school.contactPerson.phone : 'No contact' %></span>
                            </div>
                        </div>
                    </div>

                    <!-- Quick Stats -->
                    <div class="stats-grid">
                        <div class="stat-card">
                            <div class="stat-number"><%= participationAnalytics.totalEvents %></div>
                            <div class="stat-label">Events Attended</div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-number"><%= participationAnalytics.totalAttended %></div>
                            <div class="stat-label">Show Ups</div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-number"><%= participationAnalytics.avgAttendance %>%</div>
                            <div class="stat-label">Avg Attendance</div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-number"><%= scoutGroups.length %></div>
                            <div class="stat-label">Scout Groups</div>
                        </div>
                    </div>

                    <!-- Details Grid -->
                    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 1rem; margin-top: 1rem;">
                        <!-- Contact Information -->
                        <div class="content-card">
                            <div class="card-header"><h3>Contact Information</h3></div>
                            <div class="card-content">
                                <% if (school.contactPerson) { %>
                                    <p><strong>Name:</strong> <%= school.contactPerson.name %></p>
                                    <p><strong>Email:</strong> <%= school.contactPerson.email %></p>
                                    <p><strong>Phone:</strong> <%= school.contactPerson.phone %></p>
                                    <p><strong>Position:</strong> <%= school.contactPerson.position || 'Not specified' %></p>
                                <% } else { %>
                                    <p class="placeholder-text">No contact information recorded.</p>
                                <% } %>
                                <hr style="margin: 1rem 0; border: none; border-top: 1px solid var(--border);">
                                <p><strong>Zone:</strong> <%= school.zone || 'Not assigned' %></p>
                                <p><strong>Region:</strong> <%= school.region || 'Not assigned' %></p>
                                <p><strong>Service Package:</strong> <%= school.servicePackage || 'standard' %></p>
                                <p><strong>Service Status:</strong> <span class="badge badge-<%= school.serviceStatus === 'active' ? 'success' : school.serviceStatus === 'on_hold' ? 'warning' : 'secondary' %>"><%= school.serviceStatus.replace('_', ' ') %></span></p>
                            </div>
                        </div>

                        <!-- Assigned Trainers -->
                        <div class="content-card">
                            <div class="card-header"><h3>Assigned Trainers</h3></div>
                            <div class="card-content">
                                <% if (school.assignedStaff && school.assignedStaff.length > 0) { %>
                                    <% school.assignedStaff.forEach(staff => { %>
                                        <div style="padding: 0.75rem; border: 1px solid var(--border); border-radius: var(--radius); margin-bottom: 0.5rem;">
                                            <strong><%= staff.name || staff.email %></strong><br>
                                            <small style="color: var(--muted-foreground);">
                                                <%= staff.role || 'Trainer' %> 
                                                (<%= staff.idNumber || 'No ID' %>)
                                            </small>
                                        </div>
                                    <% }) %>
                                <% } else { %>
                                    <p class="placeholder-text">No trainers assigned yet.</p>
                                    <% if (req.session.user.permissions && req.session.user.permissions.canAssignTrainers) { %>
                                        <button class="btn btn-sm btn-primary" onclick="window.location.href='/trainer/allocation'">Assign Trainer</button>
                                    <% } %>
                                <% } %>
                            </div>
                        </div>

                        <!-- Scout Groups -->
                        <div class="content-card">
                            <div class="card-header">
                                <h3>Scout Groups</h3>
                                <button class="btn btn-sm btn-primary" onclick="window.DashboardUtils.openAddScoutGroupModal('<%= school._id %>')">+ Add Group</button>
                            </div>
                            <div class="card-content">
                                <% if (scoutGroups && scoutGroups.length > 0) { %>
                                    <% scoutGroups.forEach(group => { %>
                                        <div style="padding: 0.75rem; border: 1px solid var(--border); border-radius: var(--radius); margin-bottom: 0.5rem; display: flex; justify-content: space-between; align-items: center;">
                                            <div>
                                                <strong><%= group.name %></strong> (<%= group.advancementLevel || 'unknown' %>)<br>
                                                <small>👤 <%= group.memberCount || 0 %> members | 🎯 <%= group.patrol || 'No patrol' %></small>
                                            </div>
                                            <button class="btn btn-sm btn-outline btn-danger" onclick="deleteScoutGroup('<%= group._id %>')">Delete</button>
                                        </div>
                                    <% }) %>
                                <% } else { %>
                                    <p class="placeholder-text">No scout groups registered.</p>
                                <% } %>
                            </div>
                        </div>

                        <!-- Recent Visit Logs -->
                        <div class="content-card">
                            <div class="card-header"><h3>Recent Visits</h3></div>
                            <div class="card-content">
                                <% if (visitLogs && visitLogs.length > 0) { %>
                                    <% visitLogs.slice(0, 5).forEach(log => { %>
                                        <div style="padding: 0.5rem 0; border-bottom: 1px solid var(--border);">
                                            <div style="font-weight: 500;"><%= log.purpose %></div>
                                            <div style="font-size: 0.85rem; color: var(--muted-foreground);">
                                                <%= log.date ? new Date(log.date).toLocaleDateString() : 'Date unknown' %> 
                                                <span style="margin-left: auto;">
                                                    <%= log.discussed ? ' - ' + log.discussed.substring(0, 50) + '...' : '' %>
                                                </span>
                                            </div>
                                        </div>
                                    <% }) %>
                                <% } else { %>
                                    <p class="placeholder-text">No visit records found.</p>
                                <% } %>
                            </div>
                        </div>

                        <!-- Event Participation History -->
                        <div class="content-card">
                            <div class="card-header"><h3>Event History</h3></div>
                            <div class="card-content">
                                <table class="data-table">
                                    <thead><tr><th>Event</th><th>Date</th><th>Attendance</th><th>Status</th></tr></thead>
                                    <tbody>
                                        <% if (schoolEvents && schoolEvents.length > 0) { %>
                                            <% schoolEvents.slice(0, 10).forEach(se => { %>
                                                <tr>
                                                    <td><%= se.event && se.event.name ? se.event.name : 'Unknown Event' %></td>
                                                    <td><%= se.event && se.event.date ? new Date(se.event.date).toLocaleDateString() : '—' %></td>
                                                    <td><%= se.attendance ? se.attendance.attended + '/' + se.attendance.registered + ' (' + se.attendance.percentage + '%)' : '0/0 (0%)' %></td>
                                                    <td><span class="badge badge-<%= se.status === 'attended' ? 'success' : se.status === 'cancelled' ? 'danger' : 'warning' %>"><%= se.status %></span></td>
                                                </tr>
                                            <% }) %>
                                        <% } else { %>
                                            <tr><td colspan="4" class="placeholder-text">No event participation recorded.</td></tr>
                                        <% } %>
                                    </tbody>
                                </table>
                            </div>
                        </div>

                        <!-- Payment History -->
                        <div class="content-card">
                            <div class="card-header"><h3>Payment History</h3></div>
                            <div class="card-content">
                                <% if (payments && payments.length > 0) { %>
                                    <table class="data-table">
                                        <thead><tr><th>Date</th><th>Invoice</th><th>Amount</th><th>Status</th></tr></thead>
                                        <tbody>
                                            <% payments.slice(0, 5).forEach(payment => { %>
                                                <tr>
                                                    <td><%= payment.paymentDate ? new Date(payment.paymentDate).toLocaleDateString() : '—' %></td>
                                                    <td><%= payment.invoiceNumber %></td>
                                                    <td><%= payment.currency %> <%= payment.amount.toLocaleString() %></td>
                                                    <td><span class="badge badge-<%= payment.status === 'paid' ? 'success' : payment.status === 'pending' ? 'warning' : 'danger' %>"><%= payment.status %></span></td>
                                                </tr>
                                            <% }) %>
                                        </tbody>
                                    </table>
                                <% } else { %>
                                    <p class="placeholder-text">No payment records.</p>
                                <% } %>
                            </div>
                        </div>

                        <!-- Documents -->
                        <div class="content-card">
                            <div class="card-header"><h3>Documents</h3></div>
                            <div class="card-content">
                                <% if (documents && documents.length > 0) { %>
                                    <ul style="list-style: none; padding: 0;">
                                        <% documents.forEach(doc => { %>
                                            <li style="padding: 0.5rem 0; border-bottom: 1px solid var(--border); display: flex; justify-content: space-between;">
                                                <span>📄 <%= doc.name %> (<%= doc.documentType %>)</span>
                                                <a href="<%= doc.url %>" target="_blank" class="btn btn-sm btn-outline">View</a>
                                            </li>
                                        <% }) %>
                                    </ul>
                                <% } else { %>
                                    <p class="placeholder-text">No documents uploaded.</p>
                                <% } %>
                            </div>
                        </div>

                        <!-- Notes Section -->
                        <div class="content-card">
                            <div class="card-header"><h3>School Notes</h3></div>
                            <div class="card-content">
                                <% if (school.notes) { %>
                                    <p><%= school.notes %></p>
                                <% } else { %>
                                    <p class="placeholder-text">No notes recorded.</p>
                                <% } %>
                                <% if (school.visitNotes && school.visitNotes.length > 0) { %>
                                    <hr style="margin: 1rem 0;">
                                    <h4>Visit Notes</h4>
                                    <% school.visitNotes.forEach(note => { %>
                                        <div style="font-size: 0.9rem;">
                                            <strong><%= note.date ? new Date(note.date).toLocaleDateString() : 'Date unknown' %></strong><br>
                                            <%= note.content %>
                                        </div>
                                    <% }) %>
                                <% } %>
                            </div>
                        </div>
                    </div>
                 <% } else if (page === 'events') { %>
                    <!-- Events Management Page -->
                    <div class="stats-grid">
                        <div class="stat-card">
                            <div class="stat-icon">📅</div>
                            <div><div class="stat-number" id="upcomingEventsCount">0</div><div class="stat-label">Upcoming Events</div></div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-icon">📨</div>
                            <div><div class="stat-number" id="pendingInvitationsCount">0</div><div class="stat-label">Pending Invitations</div></div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-icon">✅</div>
                            <div><div class="stat-number" id="confirmedSchoolsCount">0</div><div class="stat-label">Confirmed Schools</div></div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-icon">🚩</div>
                            <div><div class="stat-number" id="eventsThisWeekCount">0</div><div class="stat-label">Events This Week</div></div>
                        </div>
                    </div>

                    <!-- Filters & Controls -->
                    <div class="content-card" style="margin-bottom: 1.5rem;">
                        <div class="card-header">
                            <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem;">
                                <div style="display: flex; gap: 0.75rem; align-items: center; flex-wrap: wrap;">
                                    <h3>Events Management</h3>
                                    <input type="text" id="eventSearch" placeholder="Search events..." style="padding: 0.5rem; border: 1px solid var(--border); border-radius: var(--radius); width: 200px;">
                                    <select id="typeFilter" style="padding: 0.5rem; border: 1px solid var(--border); border-radius: var(--radius);">
                                        <option value="">All Types</option>
                                        <option value="camp">Camp</option>
                                        <option value="hike">Hike</option>
                                        <option value="team_building">Team Building</option>
                                        <option value="training_session">Training Session</option>
                                        <option value="inter_school_competition">Inter-School Competition</option>
                                        <option value="other">Other</option>
                                    </select>
                                     <select id="statusFilter" style="padding: 0.5rem; border: 1px solid var(--border); border-radius: var(--radius);">
                                         <option value="">All Statuses</option>
                                         <option value="draft">Draft</option>
                                         <option value="scheduled">Scheduled</option>
                                         <option value="confirmed">Confirmed</option>
                                         <option value="in_progress">In Progress</option>
                                         <option value="completed">Completed</option>
                                         <option value="reviewed">Reviewed</option>
                                         <option value="cancelled">Cancelled</option>
