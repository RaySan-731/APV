<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - Arrow-Park Ventures</title>
    <link rel="stylesheet" href="/css/styles.css">
    <link rel="icon" href="/favicon.ico">
</head>
<body>
    <div class="login-container">
        <div class="login-header">
            <a href="/" class="back-link">
                <svg class="back-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M19 12H5"></path>
                    <path d="M12 19l-7-7 7-7"></path>
                </svg>
                Back to Home
            </a>
        </div>

        <div class="login-card">
            <div class="login-logo">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M17 14V2"></path>
                    <path d="M9 18.12L10 14H4l1.88-4.12L9 18.12z"></path>
                    <path d="M13 22l3-8"></path>
                    <path d="M7 22l3-8"></path>
                </svg>
            </div>

            <h1 class="login-title">Member Login</h1>
            <p class="login-subtitle">Access your Arrow-Park Ventures dashboard</p>

            <% if (typeof error !== 'undefined') { %>
                <div class="alert alert-error">
                    <%= error %>
                </div>
            <% } %>

                    <form class="login-form" action="/login" method="POST">
                        <% if (typeof next !== 'undefined' && next) { %>
                            <input type="hidden" name="next" value="<%= next %>">
                        <% } %>
                <div class="form-group">
                    <label for="email" class="form-label">Email</label>
                    <input
                        type="email"
                        id="email"
                        name="email"
                        class="form-input"
                        required
                        placeholder="Enter your email"
                    >
                </div>

                <div class="form-group">
                    <label for="password" class="form-label">Password</label>
                    <input
                        type="password"
                        id="password"
                        name="password"
                        class="form-input"
                        required
                        placeholder="Enter your password"
                    >
                </div>

                <button type="submit" class="btn btn-primary btn-full">Sign In</button>
            </form>

            <div class="login-footer">
                <p>Demo credentials: founder@apventures.com / admin</p>
            </div>
        </div>
    </div>

    <script src="/js/main.js"></script>
</body>
</html>