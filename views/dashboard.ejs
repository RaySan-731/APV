<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard - Arrow-Park Ventures</title>
    <link rel="stylesheet" href="/css/styles.css">
    <link rel="icon" href="/favicon.ico">
</head>
<body>
    <div class="dashboard-layout">
        <!-- Sidebar -->
        <aside class="sidebar" id="sidebar">
            <div class="sidebar-header">
                <div class="sidebar-brand">
                    <svg class="sidebar-logo" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M17 14V2"></path>
                        <path d="M9 18.12L10 14H4l1.88-4.12L9 18.12z"></path>
                        <path d="M13 22l3-8"></path>
                        <path d="M7 22l3-8"></path>
                    </svg>
                    <span>Arrow-Park Ventures</span>
                </div>
                <button class="sidebar-toggle" id="sidebarToggle">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M3 12h18"></path>
                        <path d="M3 6h18"></path>
                        <path d="M3 18h18"></path>
                    </svg>
                </button>
            </div>

            <nav class="sidebar-nav">
                <div class="nav-section">
                    <h3 class="nav-section-title">Main Menu</h3>
                    <ul class="nav-list">
                        <li class="nav-item">
                            <a href="/dashboard" class="nav-link <%= page === 'dashboard' ? 'active' : '' %>">
                                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
                                    <polyline points="9,22 9,12 15,12 15,22"></polyline>
                                </svg>
                                Dashboard
                            </a>
                        </li>
                        <li class="nav-item">
                            <a href="/dashboard/analytics" class="nav-link <%= page === 'analytics' ? 'active' : '' %>">
                                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M3 3v18h18"></path>
                                    <path d="M18.7 8l-5.1 5.2-2.8-2.7L7 14.3"></path>
                                </svg>
                                Analytics
                            </a>
                        </li>
                        <li class="nav-item">
                            <a href="/dashboard/staff" class="nav-link <%= page === 'staff' ? 'active' : '' %>">
                                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                                    <circle cx="9" cy="7" r="4"></circle>
                                    <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
                                    <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
                                </svg>
                                Staff Management
                            </a>
                        </li>
                        <li class="nav-item">
                            <a href="/dashboard/schools" class="nav-link <%= page === 'schools' ? 'active' : '' %>">
                                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M12 2l3 3 3-3v8a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2V2l3 3 3-3z"></path>
                                    <path d="M2 12h20"></path>
                                    <path d="M6 12v8"></path>
                                    <path d="M18 12v8"></path>
                                </svg>
                                Schools
                            </a>
                        </li>
                        <li class="nav-item">
                            <a href="/dashboard/events" class="nav-link <%= page === 'events' ? 'active' : '' %>">
                                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                                    <line x1="16" y1="2" x2="16" y2="6"></line>
                                    <line x1="8" y1="2" x2="8" y2="6"></line>
                                    <line x1="3" y1="10" x2="21" y2="10"></line>
                                </svg>
                                Events
                            </a>
                        </li>
                        <li class="nav-item">
                            <a href="/dashboard/programs" class="nav-link <%= page === 'programs' ? 'active' : '' %>">
                                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                                    <polyline points="14,2 14,8 20,8"></polyline>
                                    <line x1="16" y1="13" x2="8" y2="13"></line>
                                    <line x1="16" y1="17" x2="8" y2="17"></line>
                                    <polyline points="10,9 9,9 8,9"></polyline>
                                </svg>
                                Programs
                            </a>
                        </li>
                        <li class="nav-item">
                            <a href="/dashboard/trainers" class="nav-link <%= page === 'trainers' ? 'active' : '' %>">
                                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                                    <circle cx="9" cy="7" r="4"></circle>
                                    <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
                                    <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
                                </svg>
                                Trainers
                            </a>
                        </li>
                        <li class="nav-item">
                            <a href="/dashboard/settings" class="nav-link <%= page === 'settings' ? 'active' : '' %>">
                                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <circle cx="12" cy="12" r="3"></circle>
                                    <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1 1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"></path>
                                </svg>
                                Settings
                            </a>
                        </li>
                    </ul>
                </div>

                <div class="nav-section">
                    <h3 class="nav-section-title">Support</h3>
                    <ul class="nav-list">
                        <li class="nav-item">
                            <a href="/help" class="nav-link">
                                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <circle cx="12" cy="12" r="10"></circle>
                                    <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"></path>
                                    <path d="M12 17h.01"></path>
                                </svg>
                                Help & FAQ
                            </a>
                        </li>
                    </ul>
                </div>
            </nav>

            <div class="sidebar-footer">
                <a href="/logout" class="logout-btn">
                    <svg class="logout-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
                        <polyline points="16,17 21,12 16,7"></polyline>
                        <line x1="21" y1="12" x2="9" y2="12"></line>
                    </svg>
                    Logout
                </a>
            </div>
        </aside>

        <!-- Main Content -->
        <main class="main-content">
            <header class="dashboard-header">
                <button class="mobile-sidebar-toggle" id="mobileSidebarToggle">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M3 12h18"></path>
                        <path d="M3 6h18"></path>
                        <path d="M3 18h18"></path>
                    </svg>
                </button>
                <h1 class="page-title">
                    <% if (page === 'dashboard') { %>Dashboard<% } %>
                    <% if (page === 'analytics') { %>Analytics<% } %>
                    <% if (page === 'staff') { %>Staff Management<% } %>
                    <% if (page === 'schools') { %>Schools<% } %>
                    <% if (page === 'events') { %>Events<% } %>
                    <% if (page === 'programs') { %>Programs<% } %>
                    <% if (page === 'settings') { %>Settings<% } %>
                    <% if (page === 'trainers') { %>Trainers<% } %>
                    <% if (page === 'schedule') { %>Training Schedule<% } %>
                    <% if (page === 'health') { %>Health Records<% } %>
                </h1>
                <div class="user-info">
                    <span>Welcome, <%= user.name %></span>
                </div>
            </header>

            <div class="dashboard-content">
                <% if (page === 'dashboard') { %>
                    <!-- Dashboard Stats -->
                    <div class="stats-grid">
                        <div class="stat-card">
                            <div class="stat-icon">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M12 2l3 3 3-3v8a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2V2l3 3 3-3z"></path>
                                    <path d="M2 12h20"></path>
                                    <path d="M6 12v8"></path>
                                    <path d="M18 12v8"></path>
                                </svg>
                            </div>
                            <div class="stat-number" id="totalSchools">25</div>
                            <div class="stat-label">Total Schools</div>
                            <div class="stat-change">+3 this month</div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-icon">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                                    <circle cx="9" cy="7" r="4"></circle>
                                    <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
                                    <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
                                </svg>
                            </div>
                            <div class="stat-number" id="activeStudents">523</div>
                            <div class="stat-label">Active Students</div>
                            <div class="stat-change">+48 this week</div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-icon">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                                    <line x1="16" y1="2" x2="16" y2="6"></line>
                                    <line x1="8" y1="2" x2="8" y2="6"></line>
                                    <line x1="3" y1="10" x2="21" y2="10"></line>
                                </svg>
                            </div>
                            <div class="stat-number" id="upcomingEvents">8</div>
                            <div class="stat-label">Upcoming Events</div>
                            <div class="stat-change">Next: Summer Camp</div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-icon">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M3 3v18h18"></path>
                                    <path d="M18.7 8l-5.1 5.2-2.8-2.7L7 14.3"></path>
                                </svg>
                            </div>
                            <div class="stat-number" id="growthRate">+24%</div>
                            <div class="stat-label">Growth Rate</div>
                            <div class="stat-change">Year over year</div>
                        </div>
                    </div>

                    <!-- Recent Activities -->
                    <div class="content-card">
                        <div class="card-header">
                            <h3>Recent Activities</h3>
                        </div>
                        <div class="card-content">
                            <div class="activity-list" id="recentActivities">
                                <!-- Activities will be loaded via JavaScript -->
                            </div>
                        </div>
                    </div>
                <% } else if (page === 'analytics') { %>
                    <div class="stats-grid">
                        <div class="stat-card"><div class="stat-icon">📊</div><div><div class="stat-number">96%</div><div class="stat-label">Platform Uptime</div></div></div>
                        <div class="stat-card"><div class="stat-icon">⏱</div><div><div class="stat-number">0.28s</div><div class="stat-label">Avg Response Time</div></div></div>
                        <div class="stat-card"><div class="stat-icon">📈</div><div><div class="stat-number">128</div><div class="stat-label">Reports Generated</div></div></div>
                        <div class="stat-card"><div class="stat-icon">💬</div><div><div class="stat-number">72</div><div class="stat-label">Active Communications</div></div></div>
                    </div>
                    <div class="content-card"><div class="card-header"><h3>Analytics Insights</h3></div><div class="card-content"><p>Real-time KPIs include staff productivity, school participation, and event engagement. Use this dashboard to identify bottlenecks and improve turn-around time for program booking.</p></div></div>
                <% } else if (page === 'staff') { %>
                    <div class="stats-grid">
                        <div class="stat-card"><div class="stat-icon">👥</div><div><div class="stat-number">48</div><div class="stat-label">Total Staff</div></div></div>
                        <div class="stat-card"><div class="stat-icon">🟢</div><div><div class="stat-number">39</div><div class="stat-label">Active Staff</div></div></div>
                        <div class="stat-card"><div class="stat-icon">🛑</div><div><div class="stat-number">5</div><div class="stat-label">On Leave</div></div></div>
                        <div class="stat-card"><div class="stat-icon">📌</div><div><div class="stat-number">4</div><div class="stat-label">Pending Approvals</div></div></div>
                    </div>
                    <div class="content-card">
                        <div class="card-header"><h3>Staff Directory</h3></div>
                        <div class="card-content">
                            <table class="data-table">
                                <thead><tr><th>ID Number</th><th>Name</th><th>Email</th><th>Role</th><th>Status</th><th>Actions</th></tr></thead>
                                <tbody>
                                <% if (staffList && staffList.length > 0) { %>
                                    <% staffList.forEach(staff => { %>
                                        <tr>
                                            <td><%= staff.idNumber || '—' %></td>
                                            <td><%= staff.name %></td>
                                            <td><%= staff.email %></td>
                                            <td><%= staff.role %></td>
                                            <td><%= staff.status %></td>
                                            <td>
                                                <button type="button" class="btn btn-sm btn-outline" onclick="editStaff('<%= staff._id %>', '<%= staff.idNumber || '' %>', '<%= staff.name %>', '<%= staff.email %>', '<%= staff.role %>', '<%= staff.status %>')">Edit</button>
                                                <button type="button" class="btn btn-sm btn-outline" onclick="deleteStaff('<%= staff._id %>')">Delete</button>
                                            </td>
                                        </tr>
                                    <% }) %>
                                <% } else { %>
                                    <tr><td colspan="6" class="placeholder-text">No staff entries found yet.</td></tr>
                                <% } %>
                            </tbody>
                            </table>
                        </div>
                    </div>
                    <div class="content-card">
                        <div class="card-header"><h3>Add New Staff Member</h3></div>
                        <div class="card-content">
                            <form action="/dashboard/staff/add" method="POST" class="form-grid">
                                <label>ID Number<input type="text" name="idNumber"></label>
                                <label>Name<input type="text" name="name" required></label>
                                <label>Email<input type="email" name="email" required></label>
                                <label>Role<input type="text" name="role" required></label>
                                <label>Status<select name="status"><option>Active</option><option>On Leave</option><option>Inactive</option></select></label>
                                <button type="submit" class="btn btn-primary">Add Staff</button>
                            </form>
                        </div>
                    </div>

                    <!-- Edit Staff Modal -->
                    <div id="editStaffModal" class="modal" style="display: none;">
                        <div class="modal-content">
                            <div class="modal-header">
                                <h3>Edit Staff Member</h3>
                                <button type="button" class="close-btn" onclick="closeEditStaffModal()">×</button>
                            </div>
                            <div class="modal-body">
                                <form id="editStaffForm" class="form-grid">
                                    <input type="hidden" id="editStaffId" name="staffId">
                                    <label>ID Number<input type="text" id="editIdNumber" name="idNumber"></label>
                                    <label>Name<input type="text" id="editName" name="name" required></label>
                                    <label>Email<input type="email" id="editEmail" name="email" required></label>
                                    <label>Role<input type="text" id="editRole" name="role" required></label>
                                    <label>Status<select id="editStatus" name="status">
                                        <option>Active</option>
                                        <option>On Leave</option>
                                        <option>Inactive</option>
                                    </select></label>
                                    <div id="editMessage" class="message" style="display: none; grid-column: 1 / -1; margin-top: 1rem;"></div>
                                </form>
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-secondary" onclick="closeEditStaffModal()">Cancel</button>
                                <button type="button" class="btn btn-primary" onclick="saveEditStaff()">Save Changes</button>
                            </div>
                        </div>
                    </div>
                <% } else if (page === 'schools') { %>
                    <div class="stats-grid">
                        <div class="stat-card"><div class="stat-icon">🏫</div><div><div class="stat-number">32</div><div class="stat-label">Partner Schools</div></div></div>
                        <div class="stat-card"><div class="stat-icon">👧</div><div><div class="stat-number">930</div><div class="stat-label">Students Enrolled</div></div></div>
                        <div class="stat-card"><div class="stat-icon">📆</div><div><div class="stat-number">18</div><div class="stat-label">Active Programs</div></div></div>
                        <div class="stat-card"><div class="stat-icon">📍</div><div><div class="stat-number">10</div><div class="stat-label">Regions Covered</div></div></div>
                    </div>
                    <div class="content-card">
                        <div class="card-header"><h3>School Participation</h3></div>
                        <div class="card-content">
                            <table class="data-table">
                                <thead><tr><th>School</th><th>County</th><th>Programs</th><th>Progress</th><th>Status</th></tr></thead>
                                <tbody>
                                    <% if (schoolList && schoolList.length > 0) { %>
                                        <% schoolList.forEach(school => { %>
                                            <tr>
                                                <td><%= school.name %></td>
                                                <td><%= (school.address && school.address.city) || '—' %></td>
                                                <td><%= (school.programsEnrolled && school.programsEnrolled.length > 0) ? school.programsEnrolled.length : '0' %></td>
                                                <td><%= school.studentCount || 0 %></td>
                                                <td><%= school.status %></td>
                                            </tr>
                                        <% }) %>
                                    <% } else { %>
                                        <tr><td colspan="5" class="placeholder-text">No partner schools found yet.</td></tr>
                                    <% } %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                    <div class="content-card">
                        <div class="card-header"><h3>Add Partner School</h3></div>
                        <div class="card-content">
                            <form action="/dashboard/schools/add" method="POST" class="form-grid">
                                <label>Name<input type="text" name="name" required></label>
                                <label>Street<input type="text" name="street"></label>
                                <label>City<input type="text" name="city"></label>
                                <label>State<input type="text" name="state"></label>
                                <label>Zip Code<input type="text" name="zipCode"></label>
                                <label>Country<input type="text" name="country" value="Kenya"></label>
                                <label>Contact Name<input type="text" name="contactName"></label>
                                <label>Contact Email<input type="email" name="contactEmail"></label>
                                <label>Contact Phone<input type="text" name="contactPhone"></label>
                                <label>Student Count<input type="number" name="studentCount" min="0" value="0"></label>
                                <label>Status<select name="status"><option value="active">Active</option><option value="pending">Pending</option><option value="inactive">Inactive</option></select></label>
                                <button type="submit" class="btn btn-primary">Add School</button>
                            </form>
                        </div>
                    </div>
                <% } else if (page === 'events') { %>
                    <div class="stats-grid">
                        <div class="stat-card"><div class="stat-icon">📅</div><div><div class="stat-number">14</div><div class="stat-label">Upcoming Events</div></div></div>
                        <div class="stat-card"><div class="stat-icon">🚩</div><div><div class="stat-number">4</div><div class="stat-label">Pending Approvals</div></div></div>
                        <div class="stat-card"><div class="stat-icon">🎓</div><div><div class="stat-number">520</div><div class="stat-label">Registered Scouts</div></div></div>
                        <div class="stat-card"><div class="stat-icon">⏳</div><div><div class="stat-number">3</div><div class="stat-label">Events this Week</div></div></div>
                    </div>
                    <div class="content-card">
                        <div class="card-header"><h3>Event Schedule</h3></div>
                        <div class="card-content">
                            <table class="data-table">
                                <thead><tr><th>Event</th><th>Date</th><th>Location</th><th>Team</th><th>Status</th></tr></thead>
                                <tbody>
                                    <% if (eventList && eventList.length > 0) { %>
                                        <% eventList.forEach(event => { %>
                                            <tr>
                                                <td><%= event.name %></td>
                                                <td><%= event.date ? new Date(event.date).toLocaleDateString() : 'TBD' %></td>
                                                <td><%= event.location %></td>
                                                <td><%= event.team || 'TBD' %></td>
                                                <td><%= event.status %></td>
                                            </tr>
                                        <% }) %>
                                    <% } else { %>
                                        <tr><td colspan="5" class="placeholder-text">No events scheduled yet.</td></tr>
                                    <% } %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                    <div class="content-card">
                        <div class="card-header"><h3>Add Event</h3></div>
                        <div class="card-content">
                            <form action="/dashboard/events/add" method="POST" class="form-grid">
                                <label>Event Name<input type="text" name="name" required></label>
                                <label>Date<input type="date" name="date" required></label>
                                <label>Location<input type="text" name="location" required></label>
                                <label>Team<input type="text" name="team"></label>
                                <label>Registered Count<input type="number" min="0" name="registeredCount" value="0"></label>
                                <label>Status<select name="status"><option>Planning</option><option>Confirmed</option><option>Completed</option><option>Cancelled</option></select></label>
                                <button type="submit" class="btn btn-primary">Add Event</button>
                            </form>
                        </div>
                    </div>
                <% } else if (page === 'programs') { %>
                    <div class="stats-grid">
                        <div class="stat-card"><div class="stat-icon">📚</div><div><div class="stat-number">28</div><div class="stat-label">Program Offerings</div></div></div>
                        <div class="stat-card"><div class="stat-icon">🏕</div><div><div class="stat-number">9</div><div class="stat-label">Live Programs</div></div></div>
                        <div class="stat-card"><div class="stat-icon">🕒</div><div><div class="stat-number">12</div><div class="stat-label">Upcoming Starts</div></div></div>
                        <div class="stat-card"><div class="stat-icon">🧾</div><div><div class="stat-number">5</div><div class="stat-label">New Proposals</div></div></div>
                    </div>
                    <div class="content-card">
                        <div class="card-header"><h3>Program Catalog</h3></div>
                        <div class="card-content">
                            <table class="data-table">
                                <thead><tr><th>Name</th><th>Category</th><th>Duration</th><th>Enrollment</th><th>Status</th></tr></thead>
                                <tbody>
                                    <% if (programList && programList.length > 0) { %>
                                        <% programList.forEach(program => { %>
                                            <tr>
                                                <td><%= program.name %></td>
                                                <td><%= program.category %></td>
                                                <td><%= program.duration %></td>
                                                <td><%= program.maxParticipants %></td>
                                                <td><%= program.status %></td>
                                            </tr>
                                        <% }) %>
                                    <% } else { %>
                                        <tr><td colspan="5" class="placeholder-text">No programs available yet.</td></tr>
                                    <% } %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                    <div class="content-card">
                        <div class="card-header"><h3>Add Program</h3></div>
                        <div class="card-content">
                            <form action="/dashboard/programs/add" method="POST" class="form-grid">
                                <label>Name<input type="text" name="name" required></label>
                                <label>Description<textarea name="description" rows="2" required></textarea></label>
                                <label>Category<select name="category" required><option value="leadership">Leadership</option><option value="outdoor">Outdoor</option><option value="team-building">Team Building</option><option value="first-aid">First Aid</option><option value="environmental">Environmental</option><option value="community-service">Community Service</option></select></label>
                                <label>Age Min<input type="number" name="ageMin" min="5" max="18" value="8"></label>
                                <label>Age Max<input type="number" name="ageMax" min="5" max="18" value="16"></label>
                                <label>Duration<select name="duration"><option value="half-day">Half Day</option><option value="full-day">Full Day</option><option value="weekend">Weekend</option><option value="week">Week</option><option value="month">Month</option></select></label>
                                <label>Max Participants<input type="number" name="maxParticipants" min="1" value="10"></label>
                                <label>Price Amount<input type="number" step="0.01" name="priceAmount" min="0" value="0"></label>
                                <label>Price Currency<input type="text" name="priceCurrency" value="USD"></label>
                                <label>Status<select name="status"><option value="active">Active</option><option value="inactive">Inactive</option><option value="draft">Draft</option></select></label>
                                <button type="submit" class="btn btn-primary">Add Program</button>
                            </form>
                        </div>
                    </div>
                <% } else if (page === 'trainers') { %>
                    <% 
                        let totalTrainers = trainersList ? trainersList.length : 0;
                        let activeTrainers = trainersList ? trainersList.filter(t => t.status === 'Active').length : 0;
                        let onLeaveTrainers = trainersList ? trainersList.filter(t => t.status === 'On Leave').length : 0;
                        let certifiedTrainers = Math.floor(totalTrainers * 0.75); // Placeholder calculation
                    %>
                    <div class="stats-grid">
                        <div class="stat-card"><div class="stat-icon">👨‍🏫</div><div><div class="stat-number"><%= totalTrainers %></div><div class="stat-label">Total Trainers</div></div></div>
                        <div class="stat-card"><div class="stat-icon">🟢</div><div><div class="stat-number"><%= activeTrainers %></div><div class="stat-label">Active Trainers</div></div></div>
                        <div class="stat-card"><div class="stat-icon">⭐</div><div><div class="stat-number"><%= totalTrainers > 0 ? ((activeTrainers / totalTrainers * 100).toFixed(0) + '%') : '0%' %></div><div class="stat-label">Active Rate</div></div></div>
                        <div class="stat-card"><div class="stat-icon">📊</div><div><div class="stat-number"><%= onLeaveTrainers %></div><div class="stat-label">On Leave</div></div></div>
                    </div>
                    <div class="content-card">
                        <div class="card-header">
                            <h3>Trainers Directory</h3>
                        </div>
                        <div class="card-content">
                            <table class="data-table">
                                <thead><tr><th>ID Number</th><th>Name</th><th>Email</th><th>Phone</th><th>Status</th><th>Actions</th></tr></thead>
                                <tbody>
                                <% if (trainersList && trainersList.length > 0) { %>
                                    <% trainersList.forEach(trainer => { %>
                                        <tr>
                                            <td><%= trainer.idNumber || '—' %></td>
                                            <td><%= trainer.name %></td>
                                            <td><%= trainer.email %></td>
                                            <td><%= trainer.phone || '—' %></td>
                                            <td><span class="badge badge-<%= trainer.status === 'Active' ? 'success' : trainer.status === 'On Leave' ? 'warning' : 'danger' %>"><%= trainer.status %></span></td>
                                            <td>
                                                <button type="button" class="btn btn-sm btn-outline" onclick="editTrainer('<%= trainer._id %>', '<%= trainer.idNumber || '' %>', '<%= trainer.name %>', '<%= trainer.email %>', '<%= trainer.phone || '' %>', '<%= trainer.status %>')">Edit</button>
                                                <button type="button" class="btn btn-sm btn-outline" onclick="deleteTrainer('<%= trainer._id %>')">Delete</button>
                                            </td>
                                        </tr>
                                    <% }) %>
                                <% } else { %>
                                    <tr><td colspan="6" class="placeholder-text">No trainers found. Add one to get started!</td></tr>
                                <% } %>
                            </tbody>
                            </table>
                        </div>
                    </div>
                    <div class="content-card">
                        <div class="card-header">
                            <h3>Add New Trainer</h3>
                        </div>
                        <div class="card-content">
                            <form action="/dashboard/trainer/add" method="POST" class="form-grid">
                                <label>ID Number<input type="text" name="idNumber" placeholder="e.g., TRN001"></label>
                                <label>Name<input type="text" name="name" required placeholder="Full Name"></label>
                                <label>Email<input type="email" name="email" required placeholder="trainer@example.com"></label>
                                <label>Phone<input type="tel" name="phone" placeholder="+254712345678"></label>
                                <label>Status<select name="status" required>
                                    <option value="">Select Status</option>
                                    <option value="Active">Active</option>
                                    <option value="On Leave">On Leave</option>
                                    <option value="Inactive">Inactive</option>
                                </select></label>
                                <label>Password<input type="password" name="password" required placeholder="Set initial password"></label>
                                <button type="submit" class="btn btn-primary">Add Trainer</button>
                            </form>
                        </div>
                    </div>

                    <!-- Edit Trainer Modal -->
                    <div id="editTrainerModal" class="modal" style="display: none;">
                        <div class="modal-content">
                            <div class="modal-header">
                                <h3>Edit Trainer</h3>
                                <button type="button" class="close-btn" onclick="closeEditTrainerModal()">×</button>
                            </div>
                            <div class="modal-body">
                                <form id="editTrainerForm" class="form-grid">
                                    <input type="hidden" id="editTrainerId" name="trainerId">
                                    <label>ID Number<input type="text" id="editTrainerIdNumber" name="idNumber"></label>
                                    <label>Name<input type="text" id="editTrainerName" name="name" required></label>
                                    <label>Email<input type="email" id="editTrainerEmail" name="email" required></label>
                                    <label>Phone<input type="tel" id="editTrainerPhone" name="phone"></label>
                                    <label>Status<select id="editTrainerStatus" name="status" required>
                                        <option value="Active">Active</option>
                                        <option value="On Leave">On Leave</option>
                                        <option value="Inactive">Inactive</option>
                                    </select></label>
                                    <div id="editTrainerMessage" class="message" style="display: none; grid-column: 1 / -1; margin-top: 1rem;"></div>
                                </form>
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-secondary" onclick="closeEditTrainerModal()">Cancel</button>
                                <button type="button" class="btn btn-primary" onclick="saveEditTrainer()">Save Changes</button>
                            </div>
                        </div>
                    </div>
                <% } else { %>
                    <div class="content-card">
                        <div class="card-header"><h3>Page Coming Soon</h3></div>
                        <div class="card-content"><p class="placeholder-text">This section is under construction. Come back soon.</p></div>
                    </div>
                <% } %>
            </div>
        </main>
    </div>

    <script src="/js/dashboard.js"></script>
</body>
</html>
            </div>
        </main>
    </div>

    <script src="/js/dashboard.js"></script>
</body>
</html>