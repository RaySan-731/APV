<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>RSVP - <%= event.name %> | Arrow-Park Ventures</title>
    <link rel="stylesheet" href="/css/styles.css">
    <link rel="icon" href="/favicon.ico">
    <style>
        .message {
            padding: 1rem;
            border-radius: var(--radius);
            margin-bottom: 1rem;
        }
        .message.success { background: #d4edda; color: #155724; }
        .message.error { background: #f8d7da; color: #721c24; }
    </style>
</head>
<body style="background: var(--background); padding: 2rem;">
    <div style="max-width: 600px; margin: 0 auto; background: var(--card); padding: 2rem; border-radius: var(--radius); box-shadow: var(--shadow-card);">
        <h1 style="color: var(--primary); margin-bottom: 0.5rem;">Event RSVP</h1>
        <h2 style="margin-bottom: 1.5rem; font-weight: 500;"><%= event.name %></h2>

        <% if (currentStatus && currentStatus !== 'invited') { %>
            <div id="statusMessage" class="message">
                <p><strong>Your current response:</strong> <span class="badge badge-<%= currentStatus === 'confirmed' ? 'success' : currentStatus === 'declined' ? 'danger' : 'warning' %>"><%= currentStatus.replace('_', ' ') %></span></p>
                <% if (rsvpDeadline) { %>
                    <p><small>RSVP Deadline: <%= new Date(rsvpDeadline).toLocaleDateString() %></small></p>
                <% } %>
                <p>If you need to change your response, please contact the organizer directly.</p>
            </div>
        <% } else { %>

        <form id="rsvpForm" onsubmit="return false;">
            <input type="hidden" name="eventId" value="<%= event._id %>">
            <input type="hidden" name="schoolId" value="<%= schoolId %>">

            <div style="margin-bottom: 1.5rem;">
                <p><strong>Event Details:</strong></p>
                <p><strong>Date:</strong> <%= new Date(event.startDate).toLocaleDateString() %> - <%= new Date(event.endDate).toLocaleDateString() %></p>
                <p><strong>Location:</strong> <%= event.location?.name %>, <%= event.location?.city %></p>
                <% if (event.agenda) { %>
                    <p><strong>Agenda:</strong> <%= event.agenda %></p>
                <% } %>
                <% if (rsvpDeadline) { %>
                    <p><strong>RSVP Deadline:</strong> <%= new Date(rsvpDeadline).toLocaleDateString() %></p>
                <% } %>
            </div>

            <div style="margin-bottom: 1rem;">
                <label style="font-weight: 500; display: block; margin-bottom: 0.5rem;">RSVP Status *</label>
                <select name="status" id="rsvpStatus" required style="width: 100%; padding: 0.75rem; border: 1px solid var(--border); border-radius: var(--radius);">
                    <option value="">Select response...</option>
                    <option value="confirmed">Confirmed - We will attend</option>
                    <option value="declined">Declined - Cannot attend</option>
                    <option value="pending">Pending - Considering</option>
                </select>
            </div>

            <div style="margin-bottom: 1rem;">
                <label style="font-weight: 500; display: block; margin-bottom: 0.5rem;">Number of Participants (if confirmed)</label>
                <input type="number" name="participantCount" id="participantCount" min="0" style="width: 100%; padding: 0.75rem; border: 1px solid var(--border); border-radius: var(--radius);">
            </div>

            <div style="margin-bottom: 1rem;">
                <label style="font-weight: 500; display: block; margin-bottom: 0.5rem;">Additional Notes</label>
                <textarea name="notes" id="notes" rows="3" style="width: 100%; padding: 0.75rem; border: 1px solid var(--border); border-radius: var(--radius);"></textarea>
            </div>

            <button type="submit" class="btn btn-primary" style="width: 100%;">Submit RSVP</button>
            <div id="formMessage" class="message" style="display: none; margin-top: 1rem;"></div>
        </form>

        <% } %>

        <hr style="border: none; border-top: 1px solid var(--border); margin: 2rem 0;">

        <div style="color: var(--muted-foreground); font-size: 0.875rem; text-align: center;">
            <p>If you have any questions, please contact the event organizer.</p>
            <p>&copy; Arrow-Park Ventures</p>
        </div>
    </div>

    <script>
        document.getElementById('rsvpForm')?.addEventListener('submit', async function(e) {
            e.preventDefault();
            const form = e.target;
            const messageEl = document.getElementById('formMessage');
            messageEl.style.display = 'none';

            const data = {
                eventId: form.eventId.value,
                schoolId: form.schoolId.value,
                status: form.status.value,
                participantCount: form.participantCount.value,
                notes: form.notes.value
            };

            if (!data.status) {
                messageEl.textContent = 'Please select a response.';
                messageEl.className = 'message error';
                messageEl.style.display = 'block';
                return;
            }

            try {
                const res = await fetch('/api/events/rsvp', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });
                const result = await res.json();
                if (result.success) {
                    messageEl.textContent = 'Your RSVP has been submitted successfully. Thank you!';
                    messageEl.className = 'message success';
                    messageEl.style.display = 'block';
                    form.reset();
                    // Optionally reload after a few seconds
                    setTimeout(() => {
                        window.location.href = '/dashboard';
                    }, 3000);
                } else {
                    messageEl.textContent = 'Error: ' + (result.error || 'Submission failed');
                    messageEl.className = 'message error';
                    messageEl.style.display = 'block';
                }
            } catch (err) {
                messageEl.textContent = 'Network error: ' + err.message;
                messageEl.className = 'message error';
                messageEl.style.display = 'block';
            }
        });
    </script>
</body>
</html>