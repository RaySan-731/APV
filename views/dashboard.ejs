                                <h3>Edit Trainer</h3>
                                <button type="button" class="close-btn" onclick="closeEditTrainerModal()">×</button>
                            </div>
                            <div class="modal-body">
                                <form id="editTrainerForm" class="form-grid">
                                    <input type="hidden" id="editTrainerId" name="trainerId">
                                    <label>ID Number<input type="text" id="editTrainerIdNumber" name="idNumber"></label>
                                    <label>Name<input type="text" id="editTrainerName" name="name" required></label>
                                    <label>Email<input type="email" id="editTrainerEmail" name="email" required></label>
                                    <label>Phone<input type="tel" id="editTrainerPhone" name="phone"></label>
                                    <label>Status<select id="editTrainerStatus" name="status" required>
                                        <option value="Active">Active</option>
                                        <option value="On Leave">On Leave</option>
                                        <option value="Inactive">Inactive</option>
                                    </select></label>
                                    <div id="editTrainerMessage" class="message" style="display: none; grid-column: 1 / -1; margin-top: 1rem;"></div>
                                </form>
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-secondary" onclick="closeEditTrainerModal()">Cancel</button>
                                <button type="button" class="btn btn-primary" onclick="saveEditTrainer()">Save Changes</button>
                            </div>
                        </div>
                    </div>

