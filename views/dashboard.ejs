                                </div>
                                <div id="allocateMessage" class="message" style="display: none; margin-top: 1rem;"></div>
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-secondary" onclick="closeAllocateSchoolsModal()">Cancel</button>
                                <button type="button" class="btn btn-primary" onclick="saveSchoolAllocation()">Save Allocation</button>
                            </div>
                        </div>
                    </div>
                <% } else if (page === 'audit-logs') { %>
                    <div class="content-card">
                        <div class="card-header">
                            <h3>Audit Logs</h3>
                            <div class="card-actions">
                                <input type="text" id="auditSearch" placeholder="Search logs..." value="<%= auditSearch || '' %>" style="padding: 0.5rem; border: 1px solid var(--border); border-radius: var(--radius);">
                                <select id="auditActionFilter" style="padding: 0.5rem; border: 1px solid var(--border); border-radius: var(--radius);">
                                    <option value="">All Actions</option>
                                    <option value="created" <%= auditActionFilter === 'created' ? 'selected' : '' %>>Create</option>
                                    <option value="updated" <%= auditActionFilter === 'updated' ? 'selected' : '' %>>Update</option>
                                    <option value="deleted" <%= auditActionFilter === 'deleted' ? 'selected' : '' %>>Delete</option>
                                    <option value="leave_approved" <%= auditActionFilter === 'leave_approved' ? 'selected' : '' %>>Leave Approved</option>
                                    <option value="leave_rejected" <%= auditActionFilter === 'leave_rejected' ? 'selected' : '' %>>Leave Rejected</option>
                                    <option value="permission_changed" <%= auditActionFilter === 'permission_changed' ? 'selected' : '' %>>Permission Changed</option>
                                    <option value="account_activated" <%= auditActionFilter === 'account_activated' ? 'selected' : '' %>>Account Activated</option>
                                    <option value="account_deactivated" <%= auditActionFilter === 'account_deactivated' ? 'selected' : '' %>>Account Deactivated</option>
                                    <option value="password_reset" <%= auditActionFilter === 'password_reset' ? 'selected' : '' %>>Password Reset</option>
                                </select>
                                <select id="auditEntityFilter" style="padding: 0.5rem; border: 1px solid var(--border); border-radius: var(--radius);">
                                    <option value="">All Entities</option>
                                    <option value="staff" <%= auditEntityFilter === 'staff' ? 'selected' : '' %>>Staff</option>
                                    <option value="school" <%= auditEntityFilter === 'school' ? 'selected' : '' %>>School</option>
                                    <option value="event" <%= auditEntityFilter === 'event' ? 'selected' : '' %>>Event</option>
                                    <option value="program" <%= auditEntityFilter === 'program' ? 'selected' : '' %>>Program</option>
                                    <option value="booking" <%= auditEntityFilter === 'booking' ? 'selected' : '' %>>Booking</option>
                                </select>
                            </div>
                        </div>
                        <div class="card-content">
                            <table class="data-table">
                                <thead>
                                    <tr>
                                        <th>Timestamp</th>
                                        <th>Action</th>
                                        <th>Entity</th>
                                        <th>Entity Name</th>
                                        <th>Performed By</th>
                                        <th>Role</th>
                                        <th>Changes</th>
                                    </tr>
                                </thead>
                                <tbody>
                                <% if (auditLogs && auditLogs.length > 0) { %>
                                    <% auditLogs.forEach(log => { %>
                                        <tr>
                                            <td><%= new Date(log.timestamp).toLocaleString() %></td>
                                            <td>
                                                <% const actionLabel = log.action.replace(/_/g, ' ').replace(/\b\w/g, c => c.toUpperCase()); %>
                                                <% const actionType = log.action.includes('created') ? 'success' : log.action.includes('updated') ? 'warning' : log.action.includes('deleted') ? 'danger' : log.action.includes('approved') ? 'success' : log.action.includes('rejected') ? 'danger' : 'info'; %>
                                                <span class="badge badge-<%= actionType %>"><%= actionLabel %></span>
                                            </td>
                                            <td><%= log.entityType %></td>
                                            <td><%= log.entityName || '—' %></td>
                                            <td><%= log.performedBy?.userName || log.performedBy?.userId?.name || 'System' %></td>
                                            <td><%= log.performedBy?.userRole || log.performedBy?.role || '—' %></td>
                                            <td>
                                                <% if (log.changes && Object.keys(log.changes).length > 0) { %>
                                                    <details>
                                                        <summary>View Changes</summary>
                                                        <pre style="font-size: 0.8rem; margin-top: 0.5rem;"><%= JSON.stringify(log.changes, null, 2) %></pre>
                                                    </details>
                                                <% } else { %>
                                                    —
                                                <% } %>
                                            </td>
                                        </tr>
                                    <% }) %>
                                <% } else { %>
                                    <tr><td colspan="7" class="placeholder-text">No audit logs found.</td></tr>
                                <% } %>
                                </tbody>
                            </table>

                            <!-- Pagination -->
                            <% if (totalPages > 1) { %>
                                <% 
                                    const auditQueryParams = [];
                                    if (auditActionFilter) auditQueryParams.push(`action=${encodeURIComponent(auditActionFilter)}`);
                                    if (auditEntityFilter) auditQueryParams.push(`entityType=${encodeURIComponent(auditEntityFilter)}`);
                                    if (auditSearch) auditQueryParams.push(`search=${encodeURIComponent(auditSearch)}`);
                                    const auditQuery = auditQueryParams.length ? '&' + auditQueryParams.join('&') : '';
                                %>
                                <div class="pagination" style="margin-top: 2rem; text-align: center;">
                                    <% if (currentPage > 1) { %>
                                        <a href="/dashboard/audit-logs?page=<%= currentPage - 1 %><%= auditQuery %>" class="btn btn-sm btn-outline">Previous</a>
                                    <% } %>

                                    <% for (let i = Math.max(1, currentPage - 2); i <= Math.min(totalPages, currentPage + 2); i++) { %>
                                        <% if (i === currentPage) { %>
                                            <span class="btn btn-sm btn-primary" style="margin: 0 0.25rem;"><%= i %></span>
                                        <% } else { %>
                                            <a href="/dashboard/audit-logs?page=<%= i %><%= auditQuery %>" class="btn btn-sm btn-outline" style="margin: 0 0.25rem;"><%= i %></a>
                                        <% } %>
                                    <% } %>

                                    <% if (currentPage < totalPages) { %>
                                        <a href="/dashboard/audit-logs?page=<%= currentPage + 1 %><%= auditQuery %>" class="btn btn-sm btn-outline">Next</a>
                                    <% } %>
                                </div>
                            <% } %>
                        </div>
                    </div>
                <% } else if (page === 'permissions') { %>
                    <div class="content-card">
                        <div class="card-header">
                            <h3>Role Permissions Management</h3>
                        </div>
                        <div class="card-content">
                            <table class="data-table">
                                <thead>
                                    <tr>
                                        <th>Role</th>
                                        <th>View Staff</th>
                                        <th>Create Staff</th>
                                        <th>Edit Staff</th>
                                        <th>Delete Staff</th>
                                        <th>Invite Staff</th>
                                        <th>Reset Passwords</th>
                                        <th>View Schools</th>
                                        <th>Manage Schools</th>
                                        <th>Assign Trainers</th>
                                        <th>View Events</th>
                                        <th>Manage Events</th>
                                        <th>Programs</th>
                                        <th>Bookings</th>
                                        <th>Reports</th>
                                        <th>System Admin</th>
                                        <th>View Audit Logs</th>
                                        <th>Manage Permissions</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                <% if (permissionsList && permissionsList.length > 0) { %>
                                    <% permissionsList.forEach(perm => { %>
                                        <tr>
                                            <td><strong><%= perm.role %></strong></td>
                                            <td><input type="checkbox" <%= perm.permissions.canViewStaff ? 'checked' : '' %> disabled></td>
                                            <td><input type="checkbox" <%= perm.permissions.canCreateStaff ? 'checked' : '' %> disabled></td>
                                            <td><input type="checkbox" <%= perm.permissions.canEditStaff ? 'checked' : '' %> disabled></td>
                                            <td><input type="checkbox" <%= perm.permissions.canDeleteStaff ? 'checked' : '' %> disabled></td>
                                            <td><input type="checkbox" <%= perm.permissions.canInviteStaff ? 'checked' : '' %> disabled></td>
                                            <td><input type="checkbox" <%= perm.permissions.canResetPasswords ? 'checked' : '' %> disabled></td>
                                            <td><input type="checkbox" <%= perm.permissions.canViewSchools ? 'checked' : '' %> disabled></td>
                                            <td><input type="checkbox" <%= perm.permissions.canEditSchools ? 'checked' : '' %> disabled></td>
                                            <td><input type="checkbox" <%= perm.permissions.canAssignTrainers ? 'checked' : '' %> disabled></td>
                                            <td><input type="checkbox" <%= perm.permissions.canViewEvents ? 'checked' : '' %> disabled></td>
                                            <td><input type="checkbox" <%= perm.permissions.canCreateEvents ? 'checked' : '' %> disabled></td>
                                            <td><input type="checkbox" <%= perm.permissions.canViewPrograms ? 'checked' : '' %> disabled></td>
                                            <td><input type="checkbox" <%= perm.permissions.canViewBookings ? 'checked' : '' %> disabled></td>
                                            <td><input type="checkbox" <%= perm.permissions.canGenerateReports ? 'checked' : '' %> disabled></td>
                                            <td><input type="checkbox" <%= perm.permissions.canManageSystem ? 'checked' : '' %> disabled></td>
                                            <td><input type="checkbox" <%= perm.permissions.canViewAuditLogs ? 'checked' : '' %> disabled></td>
                                            <td><input type="checkbox" <%= perm.permissions.canManagePermissions ? 'checked' : '' %> disabled></td>
                                            <td>
                                                <button type="button" class="btn btn-sm btn-outline" onclick="editPermissions('<%= perm.role %>')">Edit</button>
                                            </td>
                                        </tr>
                                    <% }) %>
                                <% } else { %>
                                    <tr><td colspan="19" class="placeholder-text">No permissions configured.</td></tr>
                                <% } %>
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <!-- Edit Permissions Modal -->
                    <div id="editPermissionsModal" class="modal" style="display: none;">
                        <div class="modal-content large-modal">
                            <div class="modal-header">
                                <h3>Edit Permissions for <span id="editPermRole"></span></h3>
                                <button type="button" class="close-btn" onclick="closeEditPermissionsModal()">×</button>
                            </div>
                            <div class="modal-body">
                                <form id="editPermissionsForm" class="permissions-form">
                                    <input type="hidden" id="editPermRoleHidden" name="role">
                                    <div class="permissions-grid">
                                        <label><input type="checkbox" id="permCanViewStaff" name="canViewStaff"> View Staff</label>
                                        <label><input type="checkbox" id="permCanCreateStaff" name="canCreateStaff"> Create Staff</label>
                                        <label><input type="checkbox" id="permCanEditStaff" name="canEditStaff"> Edit Staff</label>
                                        <label><input type="checkbox" id="permCanDeleteStaff" name="canDeleteStaff"> Delete Staff</label>
                                        <label><input type="checkbox" id="permCanInviteStaff" name="canInviteStaff"> Invite Staff</label>
                                        <label><input type="checkbox" id="permCanResetPasswords" name="canResetPasswords"> Reset Passwords</label>
                                        <label><input type="checkbox" id="permCanViewSchools" name="canViewSchools"> View Schools</label>
                                        <label><input type="checkbox" id="permCanEditSchools" name="canEditSchools"> Manage Schools</label>
                                        <label><input type="checkbox" id="permCanAssignTrainers" name="canAssignTrainers"> Assign Trainers</label>
                                        <label><input type="checkbox" id="permCanViewEvents" name="canViewEvents"> View Events</label>
                                        <label><input type="checkbox" id="permCanCreateEvents" name="canCreateEvents"> Manage Events</label>
                                        <label><input type="checkbox" id="permCanViewPrograms" name="canViewPrograms"> View Programs</label>
                                        <label><input type="checkbox" id="permCanViewBookings" name="canViewBookings"> View Bookings</label>
                                        <label><input type="checkbox" id="permCanGenerateReports" name="canGenerateReports"> Generate Reports</label>
                                        <label><input type="checkbox" id="permCanManageSystem" name="canManageSystem"> Manage System</label>
                                        <label><input type="checkbox" id="permCanViewAnalytics" name="canViewAnalytics"> View Analytics</label>
                                        <label><input type="checkbox" id="permCanViewAuditLogs" name="canViewAuditLogs"> View Audit Logs</label>
                                        <label><input type="checkbox" id="permCanManagePermissions" name="canManagePermissions"> Manage Permissions</label>
                                    </div>
                                    <div id="editPermMessage" class="message" style="display: none; margin-top: 1rem;"></div>
                                </form>
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-secondary" onclick="closeEditPermissionsModal()">Cancel</button>
                                <button type="button" class="btn btn-primary" onclick="savePermissions()">Save Changes</button>
                            </div>
                        </div>
                    </div>
                <% } else { %>
                    <div class="content-card">
                        <div class="card-header"><h3>Page Coming Soon</h3></div>
                        <div class="card-content"><p class="placeholder-text">This section is under construction. Come back soon.</p></div>
                    </div>
                <% } %>
            </div>
        </main>
     </div>

     <!-- School Onboarding Wizard Modal -->
     <div id="onboardingModal" class="modal" style="display: none; z-index: 9999;">
        <div class="modal-content large-modal" style="max-width: 900px;">
            <div class="modal-header">
                <h3>Onboard New School</h3>
                <button type="button" class="close-btn" onclick="closeOnboardingModal()">×</button>
            </div>
            <div class="modal-body">
                <form id="onboardingForm">
                    <!-- Progress indicator -->
                    <div style="display: flex; justify-content: space-between; margin-bottom: 1.5rem; position: relative;">
                        <div style="position: absolute; top: 50%; left: 0; right: 0; height: 2px; background: var(--border); z-index: 0;"></div>
                        <% ['Basic Info', 'Contact', 'Service', 'Trainer'].forEach((step, i) => { %>
                            <div id="step-indicator-<%= i %>" style="position: relative; z-index: 1; background: white; padding: 0.5rem 1rem; border-radius: 1rem; font-size: 0.85rem; font-weight: <%= i === 0 ? 'bold' : 'normal' %>; color: <%= i === 0 ? 'var(--primary)' : 'var(--muted-foreground)' %>;">
                                <%= step %>
                            </div>
                        <% }) %>
                    </div>

                    <div class="form-grid">
                        <!-- Step 1: Basic Info -->
                        <div id="step-0" class="onboarding-step" style="display: grid;">
                            <h4>Basic Information</h4>
                            <label>School Name* <input type="text" name="name" required placeholder="e.g., Greenwood Academy"></label>
                            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                                <label>Street <input type="text" name="street" placeholder="123 Main St"></label>
                                <label>City <input type="text" name="city" placeholder="Nairobi"></label>
                            </div>
                            <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 1rem;">
                                <label>State/County <input type="text" name="state" placeholder="e.g., Nairobi County"></label>
                                <label>Zip Code <input type="text" name="zipCode" placeholder="00100"></label>
                                <label>Country <input type="text" name="country" value="Kenya"></label>
                            </div>
                            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                                <label>Zone <input type="text" name="zone" placeholder="e.g., Central Zone"></label>
                                <label>Region <input type="text" name="region" placeholder="e.g., Nairobi Region"></label>
                            </div>
                            <label>Number of Students <input type="number" name="studentCount" min="0" value="0"></label>
                        </div>

                        <!-- Step 2: Contact Information -->
                        <div id="step-1" class="onboarding-step" style="display: none; grid;">
                            <h4>Contact Person</h4>
                            <label>Contact Name* <input type="text" name="contactName" required placeholder="Full name of primary contact"></label>
                            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                                <label>Email* <input type="email" name="contactEmail" required placeholder="contact@school.edu"></label>
                                <label>Phone* <input type="tel" name="contactPhone" required placeholder="+254700000000"></label>
                            </div>
                            <label>Position/Title <input type="text" name="contactPosition" placeholder="e.g., Principal, HOD"></label>
                            <hr style="margin: 1rem 0; border: none; border-top: 1px solid var(--border);">
                            <h4>Additional Notes</h4>
                            <label><textarea name="notes" rows="3" placeholder="Any special requirements, notes about the school, etc."></textarea></label>
                        </div>

                        <!-- Step 3: Service & Payment -->
                        <div id="step-2" class="onboarding-step" style="display: none; grid;">
                            <h4>Service Configuration</h4>
                            <label>Service Package
                                <select name="servicePackage">
                                    <option value="basic">Basic - Essential programs</option>
                                    <option value="standard" selected>Standard - Most common</option>
                                    <option value="premium">Premium - Full suite</option>
                                    <option value="custom">Custom - Tailored</option>
                                </select>
                            </label>
                            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-top: 1rem;">
                                <label>Payment Method
                                    <select name="paymentMethod">
                                        <option value="bank_transfer">Bank Transfer</option>
                                        <option value="mpesa">M-Pesa</option>
                                        <option value="cheque">Cheque</option>
                                        <option value="cash">Cash</option>
                                    </select>
                                </label>
                                <label>Billing Cycle
                                    <select name="billingCycle">
                                        <option value="per_event">Per Event</option>
                                        <option value="monthly">Monthly</option>
                                        <option value="quarterly">Quarterly</option>
                                        <option value="annual">Annual</option>
                                    </select>
                                </label>
                            </div>
                            <label>Rate per Student (optional) <input type="number" name="ratePerStudent" min="0" step="0.01" placeholder="0.00"></label>
                        </div>

                        <!-- Step 4: Trainer Assignment -->
                        <div id="step-3" class="onboarding-step" style="display: none; grid;">
                            <h4>Assign Primary Trainer</h4>
                            <p style="font-size: 0.9rem; color: var(--muted-foreground); margin-bottom: 1rem;">Select a trainer to be the primary contact for this school.</p>
                            <label>
                                <select name="primaryTrainerId">
                                    <option value="">-- Select Trainer --</option>
                                    <% 
                                    let trainers = [];
                                    if (typeof staffList !== 'undefined') { trainers = staffList.filter(s => s.role === 'trainer' || s.role === 'senior trainer' || s.role === 'supervisor'); }
                                    %>
                                    <% trainers.forEach(trainer => { %>
                                        <option value="<%= trainer._id %>"><%= trainer.name %> (<%= trainer.email %>)</option>
                                    <% }) %>
                                </select>
                            </label>
                            <div style="grid-column: 1 / -1; margin-top: 1rem; padding: 1rem; background: var(--card); border-radius: var(--radius);">
                                <strong>Summary</strong>
                                <div id="onboardingSummary" style="font-size: 0.9rem; margin-top: 0.5rem;">
                                    Please complete all required fields.
                                </div>
                            </div>
                        </div>
                    </div>

                    <div id="onboardingMessage" class="message" style="display: none; margin-top: 1rem;"></div>

                    <div class="modal-footer" style="justify-content: space-between;">
                         <button type="button" class="btn btn-secondary" id="prevStepBtn" onclick="changeOnboardingStep(-1)" style="display: none;">Previous</button>
                         <div>
                             <button type="button" class="btn btn-secondary" onclick="closeOnboardingModal()">Cancel</button>
                             <button type="button" class="btn btn-primary" id="nextStepBtn">Next Step</button>
                         </div>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Add Scout Group Modal -->
    <div id="addScoutGroupModal" class="modal" style="display: none;">
        <div class="modal-content">
            <div class="modal-header">
                <h3>Add Scout Group</h3>
                <button type="button" class="close-btn" onclick="closeAddScoutGroupModal()">×</button>
            </div>
            <div class="modal-body">
                <form id="addScoutGroupForm" class="form-grid">
                    <input type="hidden" name="schoolId" id="scoutGroupSchoolId">
                    <label>Group Name* <input type="text" name="name" required placeholder="e.g., Leopards Patrol"></label>
                    <label>Patrol Name <input type="text" name="patrol" placeholder="e.g., Red, Blue, Green"></label>
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                        <label>Group Leader <input type="text" name="leaderName" placeholder="Leader's full name"></label>
                        <label>Leader Email <input type="email" name="leaderContactEmail" placeholder="leader@example.com"></label>
                    </div>
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                        <label>Member Count <input type="number" name="memberCount" min="0" value="0"></label>
                        <label>Advancement Level
                            <select name="advancementLevel">
                                <option value="cubs">Cubs</option>
                                <option value="scouts" selected>Scouts</option>
                                <option value="seniors">Seniors</option>
                                <option value="rovers">Rovers</option>
                                <option value="mixed">Mixed</option>
                            </select>
                        </label>
                    </div>
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                        <label>Meeting Day <input type="text" name="meetingDay" placeholder="e.g., Saturday"></label>
                        <label>Meeting Time <input type="text" name="meetingTime" placeholder="e.g., 2:00 PM - 4:00 PM"></label>
                    </div>
                    <label>Notes <textarea name="notes" rows="2" placeholder="Any additional details..."></textarea></label>
                    <div id="scoutGroupMessage" class="message" style="display: none; grid-column: 1 / -1; margin-top: 1rem;"></div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" onclick="closeAddScoutGroupModal()">Cancel</button>
                <button type="button" class="btn btn-primary" onclick="saveScoutGroup()">Add Group</button>
            </div>
        </div>
    </div>

    <!-- Analytics Modal (optional, for detailed analytics) -->
    <div id="analyticsModal" class="modal" style="display: none;">
        <div class="modal-content large-modal">
            <div class="modal-header">
                <h3>School Participation Analytics</h3>
                <button type="button" class="close-btn" onclick="closeAnalyticsModal()">×</button>
            </div>
            <div class="modal-body" id="analyticsContent">
                <!-- Analytics content will be loaded dynamically -->
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" onclick="closeAnalyticsModal()">Close</button>
                                         </div>
                                     </div>

                                     <!-- Post-Event Review Section -->
                                     <div class="manage-section" id="reviewSection">
                                         <h4>Post-Event Review</h4>
                                         <div id="reviewContent">
                                             <!-- Review status populated by JS -->
                                         </div>
                                         <div id="trainerReportForm" style="display:none; margin-top: 0.5rem; padding: 0.5rem; background: var(--muted); border-radius: var(--radius);">
                                             <label>Trainer Report</label>
                                             <textarea id="trainerReport" style="width:100%; height:100px; padding:0.5rem; border:1px solid var(--border); border-radius: var(--radius);" placeholder="Enter your post-event report..."></textarea>
                                             <label style="display:block; margin-top:0.5rem;">Actual Attendee Count</label>
                                             <input type="number" id="actualAttendeeCount" min="0" style="padding:0.5rem; width:120px; border:1px solid var(--border); border-radius: var(--radius);">
                                             <button class="btn btn-primary" style="margin-top:0.5rem;" onclick="submitTrainerReport()">Submit Report</button>
                                         </div>
                                         <div id="adminReviewActions" style="display:none; margin-top:0.5rem; padding:0.5rem; background: var(--muted); border-radius: var(--radius);">
                                             <p id="adminReviewStatus" style="margin-bottom:0.5rem;"></p>
                                             <button class="btn btn-success" onclick="approveEventReview()">Approve Report</button>
                                             <button class="btn btn-warning" onclick="requestRevision()">Request Revision</button>
                                         </div>
                                     </div>
                                  </div>

      <script>
        // Expose current user to client-side scripts
        window.currentUser = {
          id: '<%= user.id %>',
          role: '<%= user.role %>',
          name: '<%= user.name %>',
          email: '<%= user.email %>'
        };
      </script>
      <script src="/js/dashboard.js"></script>
  </body>
</html>